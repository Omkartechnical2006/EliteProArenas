<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Rate Us | Elite Pro Arenas</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: #0a0a0f;
      color: #e8e8f0;
      min-height: 100vh;
      padding: 32px 16px 60px;
    }
    .orbitron { font-family: 'Orbitron', monospace; }
    .bg-grid {
      background-image:
        linear-gradient(rgba(255,215,0,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,215,0,0.03) 1px, transparent 1px);
      background-size: 50px 50px;
    }

    /* Glows */
    .glow-tl { position:fixed;top:-80px;right:0;width:400px;height:400px;background:radial-gradient(circle,rgba(255,215,0,0.06) 0%,transparent 70%);pointer-events:none; }
    .glow-br { position:fixed;bottom:-100px;left:0;width:400px;height:400px;background:radial-gradient(circle,rgba(130,0,255,0.06) 0%,transparent 70%);pointer-events:none; }

    .container { max-width: 640px; margin: 0 auto; position: relative; z-index: 10; }

    /* Header */
    .header { text-align: center; margin-bottom: 36px; }
    .header-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(255,215,0,0.1); border: 1px solid rgba(255,215,0,0.3);
      border-radius: 50px; padding: 6px 16px; font-size: 0.72rem;
      letter-spacing: 0.15em; text-transform: uppercase; color: #ffd700;
      margin-bottom: 16px;
    }
    .header-icon { font-size: 3.5rem; margin-bottom: 12px; }
    .header-title {
      font-family: 'Orbitron', monospace;
      font-size: clamp(1.8rem, 6vw, 2.8rem);
      font-weight: 900; color: #ffd700;
      text-shadow: 0 0 30px rgba(255,215,0,0.4);
      margin-bottom: 8px;
    }
    .header-sub { color: #888; font-size: 0.9rem; }

    /* Card */
    .neon-card {
      background: rgba(0,0,0,0.55);
      border: 1px solid rgba(255,215,0,0.2);
      border-radius: 20px;
      backdrop-filter: blur(16px);
      box-shadow: 0 0 30px rgba(255,215,0,0.06);
      padding: 24px; margin-bottom: 20px;
    }
    .card-title {
      font-family: 'Orbitron', monospace;
      font-size: 0.8rem; font-weight: 700;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: #ffd700; margin-bottom: 18px;
      display: flex; align-items: center; gap: 8px;
    }

    /* Inputs */
    .field-label {
      font-size: 0.72rem; text-transform: uppercase;
      letter-spacing: 0.1em; color: #666; margin-bottom: 8px; display: block;
    }
    input[type="text"] {
      width: 100%; padding: 12px 16px;
      background: rgba(0,0,0,0.4);
      border: 1px solid rgba(255,215,0,0.18);
      border-radius: 10px; color: #e8e8f0;
      font-size: 0.9rem; font-family: 'Inter', sans-serif;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    input[type="text"]:focus {
      outline: none;
      border-color: #ffd700;
      box-shadow: 0 0 14px rgba(255,215,0,0.18);
    }
    .field-group { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    @media (max-width: 480px) { .field-group { grid-template-columns: 1fr; } }

    /* Stars */
    .rating-block {
      background: rgba(255,215,0,0.03);
      border: 1px solid rgba(255,215,0,0.12);
      border-radius: 12px; padding: 16px;
      transition: border-color 0.2s;
    }
    .rating-block:hover { border-color: rgba(255,215,0,0.25); }
    .rating-block + .rating-block { margin-top: 12px; }
    .game-name { font-size: 0.88rem; color: #d0d0e0; font-weight: 600; margin-bottom: 10px; }
    .star-row { display: flex; gap: 6px; cursor: pointer; }
    .star-icon {
      font-size: 1.8rem; transition: transform 0.15s, filter 0.15s;
      filter: grayscale(1) brightness(0.45);
    }
    .star-icon.active { filter: none; transform: scale(1.15); }
    .star-icon:hover { transform: scale(1.2); }
    .star-label { font-size: 0.75rem; color: rgba(255,215,0,0.55); margin-top: 6px; min-height: 18px; }

    /* Textarea */
    textarea {
      width: 100%; padding: 14px 16px;
      background: rgba(0,0,0,0.4);
      border: 1px solid rgba(255,215,0,0.18);
      border-radius: 10px; color: #e8e8f0;
      font-size: 0.9rem; font-family: 'Inter', sans-serif;
      resize: vertical; min-height: 100px;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    textarea:focus {
      outline: none;
      border-color: #ffd700;
      box-shadow: 0 0 14px rgba(255,215,0,0.18);
    }
    textarea::placeholder { color: #555; }

    /* Submit */
    .submit-btn {
      width: 100%; padding: 16px;
      background: linear-gradient(135deg, #ffd700, #ffaa00);
      color: #000; font-family: 'Orbitron', monospace;
      font-weight: 900; font-size: 1rem; letter-spacing: 0.12em;
      border: none; border-radius: 14px; cursor: pointer;
      transition: all 0.3s;
      box-shadow: 0 4px 24px rgba(255,215,0,0.35);
    }
    .submit-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 36px rgba(255,215,0,0.55);
    }
    .submit-btn:active { transform: translateY(0); }
    .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    /* Success modal */
    .success-modal {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.9); backdrop-filter: blur(14px);
      z-index: 200; align-items: center; justify-content: center;
    }
    .success-modal.show { display: flex; }
    .success-card {
      background: linear-gradient(135deg, #1a1a2e, #16213e);
      border: 2px solid #ffd700; border-radius: 24px;
      padding: 48px 36px; text-align: center;
      max-width: 380px; width: 90%;
      box-shadow: 0 0 60px rgba(255,215,0,0.4);
      animation: popIn 0.55s cubic-bezier(0.175,0.885,0.32,1.275);
    }
    @keyframes popIn { from{transform:scale(0.4);opacity:0} to{transform:scale(1);opacity:1} }
    @keyframes float  { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
    .float-anim { animation: float 2s ease-in-out infinite; }

    .home-btn {
      display: inline-block; margin-top: 24px;
      padding: 12px 32px; border-radius: 12px;
      background: linear-gradient(135deg, #ffd700, #ffaa00);
      color: #000; font-family: 'Orbitron', monospace;
      font-weight: 900; font-size: 0.8rem; letter-spacing: 0.1em;
      text-decoration: none; border: none; cursor: pointer;
      transition: all 0.3s;
    }
    .home-btn:hover { box-shadow: 0 0 24px rgba(255,215,0,0.5); }

    /* Already submitted */
    .submitted-card { text-align: center; padding: 48px 24px; }
  </style>
</head>
<body class="bg-grid">
  <div class="glow-tl"></div>
  <div class="glow-br"></div>

  <div class="container">

    <!-- Header -->
    <div class="header">
      <div class="header-badge">⚡ Elite Pro Arenas</div>
      <div class="header-icon">📝</div>
      <h1 class="header-title">SHARE YOUR<br>FEEDBACK</h1>
      <p class="header-sub">Help us make the fest even better! Takes less than 60 seconds. 🎉</p>
    </div>

    <% if (submitted) { %>
      <!-- Already submitted / success fallback -->
      <div class="neon-card submitted-card">
        <div style="font-size:4rem;margin-bottom:16px;">✅</div>
        <div class="orbitron" style="color:#ffd700;font-size:1.3rem;margin-bottom:8px;">THANK YOU!</div>
        <p style="color:#aaa;font-size:0.9rem;"><%= message %></p>
        <a href="/" class="home-btn" style="margin-top:24px;display:inline-block;">🏠 Home</a>
      </div>
    <% } else { %>

    <form id="feedbackForm">

      <!-- Identity -->
      <div class="neon-card">
        <div class="card-title">👤 YOUR DETAILS (Optional)</div>
        <div class="field-group">
          <div>
            <label class="field-label">Your Name</label>
            <input type="text" name="guestName" placeholder="e.g. Rahul Sharma" autocomplete="name"/>
          </div>
          <div>
            <label class="field-label">Class / Department</label>
            <input type="text" name="guestDept" placeholder="e.g. B.Tech CSE, BCA" />
          </div>
        </div>
      </div>

      <!-- Stall Rating -->
      <div class="neon-card">
        <div class="card-title">🏟️ OVERALL STALL EXPERIENCE</div>
        <div class="rating-block">
          <div class="star-row" id="stallStars" data-target="stallRating">
            <span class="star-icon" data-val="1">⭐</span>
            <span class="star-icon" data-val="2">⭐</span>
            <span class="star-icon" data-val="3">⭐</span>
            <span class="star-icon" data-val="4">⭐</span>
            <span class="star-icon" data-val="5">⭐</span>
          </div>
          <div class="star-label" id="stallLabel">Tap to rate</div>
          <input type="hidden" name="stallRating" id="stallRating"/>
        </div>
      </div>

      <!-- Game Ratings -->
      <% if (activeGames && activeGames.length > 0) { %>
      <div class="neon-card">
        <div class="card-title">🎮 RATE THE GAMES</div>
        <% activeGames.forEach((game) => { %>
        <div class="rating-block">
          <div class="game-name"><%= game.gameName %></div>
          <div class="star-row" id="gameStars_<%= game._id %>" data-target="game_<%= game._id %>">
            <span class="star-icon" data-val="1">⭐</span>
            <span class="star-icon" data-val="2">⭐</span>
            <span class="star-icon" data-val="3">⭐</span>
            <span class="star-icon" data-val="4">⭐</span>
            <span class="star-icon" data-val="5">⭐</span>
          </div>
          <input type="hidden" name="game_<%= game._id %>" id="game_<%= game._id %>"/>
        </div>
        <% }) %>
      </div>
      <% } %>

      <!-- Comments -->
      <div class="neon-card">
        <div class="card-title">💬 COMMENTS</div>
        <textarea name="comments" placeholder="What did you love? What can we improve? Any suggestions are welcome!"></textarea>
      </div>

      <!-- Submit -->
      <button type="submit" class="submit-btn" id="submitBtn">🚀 SUBMIT FEEDBACK</button>

    </form>
    <% } %>
  </div>

  <!-- Success Modal -->
  <div id="successModal" class="success-modal">
    <div class="success-card">
      <div class="float-anim" style="font-size:4rem;margin-bottom:16px;">🎊</div>
      <div class="orbitron" style="color:#ffd700;font-size:1.4rem;font-weight:900;margin-bottom:8px;">THANK YOU!</div>
      <p style="color:#aaa;font-size:0.85rem;margin-bottom:4px;">Your feedback means the world to us!</p>
      <p style="color:#666;font-size:0.8rem;">See you at the next fest! 🏆</p>
      <button onclick="window.location.href='/'" class="home-btn">🏠 GO HOME</button>
    </div>
  </div>

  <audio id="successSound">
    <source src="https://assets.mixkit.co/active_storage/sfx/1435/1435-preview.mp3" type="audio/mpeg"/>
  </audio>

  <script>
    const starLabels = ['','Poor 😞','Fair 😐','Good 😊','Great 😄','Excellent 🤩'];

    document.querySelectorAll('.star-row').forEach(row => {
      const targetId = row.dataset.target;
      const input    = document.getElementById(targetId);
      const stars    = row.querySelectorAll('.star-icon');
      const labelEl  = targetId === 'stallRating' ? document.getElementById('stallLabel') : null;
      let selected   = 0;

      stars.forEach(star => {
        star.addEventListener('mouseenter', () => {
          const val = parseInt(star.dataset.val);
          stars.forEach(s => s.classList.toggle('active', parseInt(s.dataset.val) <= val));
        });
        star.addEventListener('mouseleave', () => {
          stars.forEach(s => s.classList.toggle('active', parseInt(s.dataset.val) <= selected));
        });
        star.addEventListener('click', () => {
          selected    = parseInt(star.dataset.val);
          input.value = selected;
          stars.forEach(s => s.classList.toggle('active', parseInt(s.dataset.val) <= selected));
          if (labelEl) labelEl.textContent = starLabels[selected];
        });
      });
    });

    const form = document.getElementById('feedbackForm');
    if (form) {
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        const stallRating = document.getElementById('stallRating').value;
        if (!stallRating) {
          alert('⭐ Please rate the overall stall experience!');
          return;
        }

        const btn = document.getElementById('submitBtn');
        btn.textContent = '⏳ Submitting...';
        btn.disabled    = true;

        try {
          const formData = new FormData(form);
          const res = await fetch('/feedback/general', {
            method: 'POST',
            body: new URLSearchParams(formData)
          });

          // Play sound
          const sound = document.getElementById('successSound');
          sound.volume = 0.5;
          sound.play().catch(() => {});

          // Confetti
          confetti({ particleCount:150, spread:70, origin:{y:0.6}, colors:['#ffd700','#ffaa00','#fff8dc','#ffa500'] });
          setTimeout(() => {
            confetti({ particleCount:100, spread:120, origin:{y:0.6}, colors:['#ffd700','#ff6b6b','#ffffff'] });
          }, 500);

          document.getElementById('successModal').classList.add('show');
        } catch (err) {
          form.submit();
        }
      });
    }
  </script>
</body>
</html>
