<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin Panel | Elite Pro Arenas</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    body { font-family:'Inter',sans-serif; background:#080810; color:#e8e8f0; }
    .orbitron { font-family:'Orbitron',monospace; }
    .sidebar { background: linear-gradient(180deg,#0d0d1a 0%,#080810 100%); border-right:1px solid rgba(255,215,0,0.15); }
    .nav-item { transition:all 0.2s; border-left:3px solid transparent; }
    .nav-item.active, .nav-item:hover { background:rgba(255,215,0,0.08); border-left-color:#ffd700; color:#ffd700; }
    .card { background:rgba(13,13,26,0.8); border:1px solid rgba(255,215,0,0.15); border-radius:16px; backdrop-filter:blur(10px); }
    .card:hover { border-color:rgba(255,215,0,0.3); }
    .input-field {
      background:rgba(0,0,0,0.4); border:1px solid rgba(255,215,0,0.2);
      color:#e8e8f0; border-radius:10px; padding:10px 14px;
      width:100%; font-size:14px; transition:all 0.3s;
    }
    .input-field:focus { outline:none; border-color:#ffd700; box-shadow:0 0 12px rgba(255,215,0,0.2); }
    .btn-gold {
      background:linear-gradient(135deg,#ffd700,#e6c200);
      color:#000; font-weight:700; border:none; cursor:pointer;
      border-radius:10px; padding:10px 20px; transition:all 0.3s;
      font-size:13px; letter-spacing:0.05em;
    }
    .btn-gold:hover { box-shadow:0 0 20px rgba(255,215,0,0.5); transform:translateY(-1px); }
    .btn-red { background:rgba(239,68,68,0.15); border:1px solid rgba(239,68,68,0.3); color:#ef4444; border-radius:8px; padding:5px 12px; font-size:12px; cursor:pointer; transition:all 0.2s; }
    .btn-red:hover { background:rgba(239,68,68,0.3); }
    .btn-green { background:rgba(34,197,94,0.15); border:1px solid rgba(34,197,94,0.3); color:#22c55e; border-radius:8px; padding:5px 12px; font-size:12px; cursor:pointer; transition:all 0.2s; }
    .btn-green:hover { background:rgba(34,197,94,0.3); }
    .btn-amber { background:rgba(245,158,11,0.15); border:1px solid rgba(245,158,11,0.3); color:#f59e0b; border-radius:8px; padding:5px 12px; font-size:12px; cursor:pointer; transition:all 0.2s; }
    .btn-amber:hover { background:rgba(245,158,11,0.3); }
    .badge { display:inline-flex; align-items:center; padding:2px 10px; border-radius:20px; font-size:11px; font-weight:600; }
    .badge-green  { background:rgba(34,197,94,0.15);  color:#22c55e; border:1px solid rgba(34,197,94,0.3); }
    .badge-gray   { background:rgba(100,100,120,0.15); color:#888;    border:1px solid rgba(100,100,120,0.3); }
    .badge-purple { background:rgba(168,85,247,0.15); color:#a855f7; border:1px solid rgba(168,85,247,0.3); }
    .code-display {
      background:linear-gradient(135deg,#1a1400,#2a2000);
      border:2px solid #ffd700; border-radius:16px; padding:24px;
      text-align:center;
      box-shadow:0 0 40px rgba(255,215,0,0.3), inset 0 0 20px rgba(255,215,0,0.05);
      animation: glow-pulse 2s ease-in-out infinite;
    }
    @keyframes glow-pulse { 0%,100%{box-shadow:0 0 30px rgba(255,215,0,0.2)} 50%{box-shadow:0 0 60px rgba(255,215,0,0.5)} }
    .code-number { font-family:'Orbitron',monospace; font-size:4rem; font-weight:900; color:#ffd700; letter-spacing:0.3em; text-shadow:0 0 30px #ffd700; }
    .tab-btn { padding:10px 20px; border-radius:10px; font-size:13px; font-weight:600; cursor:pointer; transition:all 0.2s; }
    .tab-btn.active { background:rgba(255,215,0,0.15); color:#ffd700; border:1px solid rgba(255,215,0,0.4); }
    .tab-btn:not(.active) { background:transparent; color:#888; border:1px solid transparent; }
    .tab-btn:not(.active):hover { color:#ccc; background:rgba(255,255,255,0.05); }
    select.input-field option { background:#0d0d1a; }
    .autocomplete-list {
      position:absolute; z-index:50; width:100%;
      background:#0d0d1a; border:1px solid rgba(255,215,0,0.3);
      border-radius:10px; margin-top:4px; overflow:hidden;
      box-shadow:0 10px 40px rgba(0,0,0,0.8);
    }
    .autocomplete-item { padding:10px 14px; font-size:13px; cursor:pointer; transition:background 0.15s; }
    .autocomplete-item:hover { background:rgba(255,215,0,0.1); color:#ffd700; }
    table thead th { color:#ffd700; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; font-weight:700; padding:12px 16px; background:rgba(255,215,0,0.05); }
    table tbody td { padding:10px 16px; font-size:13px; border-bottom:1px solid rgba(255,255,255,0.05); }
    table tbody tr:hover td { background:rgba(255,215,0,0.03); }
    .stat-card { background:linear-gradient(135deg,rgba(13,13,26,0.9),rgba(20,20,40,0.9)); border:1px solid rgba(255,215,0,0.2); border-radius:14px; padding:20px; }
    ::-webkit-scrollbar { width:6px; }
    ::-webkit-scrollbar-track { background:transparent; }
    ::-webkit-scrollbar-thumb { background:rgba(255,215,0,0.3); border-radius:3px; }
    .prize-chip {
      display:flex; align-items:center; justify-content:space-between;
      background:rgba(255,215,0,0.05); border:1px solid rgba(255,215,0,0.15);
      border-radius:10px; padding:10px 14px; gap:8px;
      transition: border-color 0.2s;
    }
    .prize-chip:hover { border-color:rgba(255,215,0,0.35); }
    .qr-box {
      background:linear-gradient(135deg,#0d0d1a,#111122);
      border:1px solid rgba(255,215,0,0.3); border-radius:16px;
      padding:20px; text-align:center;
    }
    .qr-url {
      font-family:'Orbitron',monospace; font-size:1rem;
      color:#ffd700; word-break:break-all; letter-spacing:0.04em;
    }
    .toast {
      position:fixed; bottom:24px; right:24px; z-index:999;
      background:#1a1a2e; border:1px solid rgba(255,215,0,0.4);
      color:#e8e8f0; padding:12px 20px; border-radius:12px;
      font-size:13px; box-shadow:0 8px 32px rgba(0,0,0,0.5);
      transform:translateY(100px); opacity:0;
      transition:all 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
    }
    .toast.show { transform:translateY(0); opacity:1; }
    .toast.success { border-color:rgba(34,197,94,0.5); }
    .toast.error   { border-color:rgba(239,68,68,0.5); }
    /* Ref Dial styles */
    .ref-dial-box {
      background: linear-gradient(135deg, #0a0a18, #101025);
      border: 2px solid rgba(255,215,0,0.25); border-radius:20px;
      padding: 36px; text-align:center;
      box-shadow: 0 0 60px rgba(255,215,0,0.08);
    }
    .ref-dial-input {
      background: rgba(0,0,0,0.6); border: 2px solid rgba(255,215,0,0.4);
      color:#ffd700; border-radius:16px; padding:20px 28px;
      width:100%; font-size:2rem; font-family:'Orbitron',monospace;
      text-align:center; letter-spacing:0.3em; transition:all 0.3s;
      font-weight:900;
    }
    .ref-dial-input:focus {
      outline:none; border-color:#ffd700;
      box-shadow: 0 0 30px rgba(255,215,0,0.3);
    }
    .ref-dial-input::placeholder { color: rgba(255,215,0,0.2); font-size:1.2rem; letter-spacing:0.1em; }
    .ref-num-badge {
      display:inline-flex; align-items:center; justify-content:center;
      width:36px; height:36px; border-radius:10px; flex-shrink:0;
      font-family:'Orbitron',monospace; font-weight:900; font-size:13px;
      background:rgba(255,215,0,0.12); border:1px solid rgba(255,215,0,0.3);
      color:#ffd700;
    }
    .ref-num-badge.mystery {
      background:rgba(168,85,247,0.12); border-color:rgba(168,85,247,0.3);
      color:#a855f7;
    }
    .ref-row {
      display:flex; align-items:center; gap:12px; padding:10px 14px;
      border-radius:10px; border:1px solid rgba(255,255,255,0.04);
      background:rgba(0,0,0,0.2); transition:background 0.2s;
    }
    .ref-row:hover { background:rgba(255,215,0,0.04); border-color:rgba(255,215,0,0.12); }
  </style>
</head>
<body class="flex min-h-screen">

  <!-- Toast Notification -->
  <div id="toast" class="toast"></div>

  <!-- Sidebar -->
  <aside class="sidebar w-64 min-h-screen flex-shrink-0 flex flex-col py-6 px-0 fixed left-0 top-0 h-full overflow-y-auto z-20">
    <div class="px-6 mb-8">
      <div class="orbitron text-yellow-400 font-black text-sm tracking-widest">⚡ ELITE PRO</div>
      <div class="orbitron text-white font-black text-xl tracking-wide">ARENAS</div>
      <div class="text-yellow-500/40 text-xs mt-1 tracking-widest">ADMIN PANEL</div>
    </div>

    <nav class="flex-1">
      <a href="#section-gen"     class="nav-item active flex items-center gap-3 px-6 py-3 text-sm font-medium" onclick="showTab('gen',this)">
        <span>🎫</span> Code Generator
      </a>
      <a href="#section-prizes"  class="nav-item flex items-center gap-3 px-6 py-3 text-sm font-medium" onclick="showTab('prizes',this)">
        <span>🎡</span> Wheel Prizes
      </a>
      <a href="#section-mystery-prizes" class="nav-item flex items-center gap-3 px-6 py-3 text-sm font-medium" onclick="showTab('mystery-prizes',this)">
        <span>🎁</span> Mystery Prizes
      </a>
      <a href="#section-games"   class="nav-item flex items-center gap-3 px-6 py-3 text-sm font-medium" onclick="showTab('games',this)">
        <span>🎮</span> Manage Games
      </a>
      <a href="#section-faculty" class="nav-item flex items-center gap-3 px-6 py-3 text-sm font-medium" onclick="showTab('faculty',this)">
        <span>👨‍🏫</span> Faculty List
      </a>
      <a href="#section-players" class="nav-item flex items-center gap-3 px-6 py-3 text-sm font-medium" onclick="showTab('players',this)">
        <span>👥</span> Recent Players
      </a>
      <a href="#section-feedback" class="nav-item flex items-center gap-3 px-6 py-3 text-sm font-medium" onclick="showTab('feedback',this)">
        <span>📊</span> Feedback
        <% if (totalFeedbacks > 0) { %>
        <span class="ml-auto bg-yellow-500 text-black text-xs font-bold px-2 py-0.5 rounded-full"><%= totalFeedbacks %></span>
        <% } %>
      </a>
      <a href="#section-qr"      class="nav-item flex items-center gap-3 px-6 py-3 text-sm font-medium" onclick="showTab('qr',this)">
        <span>📲</span> QR / Share Link
      </a>
      <a href="#section-settings" class="nav-item flex items-center gap-3 px-6 py-3 text-sm font-medium" onclick="showTab('settings',this)">
        <span>⚙️</span> Prices & Settings
      </a>
      <a href="#section-revenue"  class="nav-item flex items-center gap-3 px-6 py-3 text-sm font-medium" onclick="showTab('revenue',this)">
        <span>📈</span> Revenue Analytics
      </a>
      <a href="#section-refdial"  class="nav-item flex items-center gap-3 px-6 py-3 text-sm font-medium" onclick="showTab('refdial',this)">
        <span>⚡</span> Ref Dial
      </a>
    </nav>

    <div class="px-6 mt-auto pt-6 border-t border-yellow-500/10 space-y-3">
      <a href="/" class="flex items-center gap-2 text-sm text-gray-500 hover:text-yellow-400 transition-colors">
        <span>🏠</span> View Live Site
      </a>
      <a href="/admin/logout" class="flex items-center gap-2 text-sm text-red-500/70 hover:text-red-400 transition-colors">
        <span>🚪</span> Logout
      </a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="ml-64 flex-1 p-8">

    <!-- Top Bar -->
    <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
      <div>
        <h1 class="orbitron text-2xl font-black text-white tracking-wide">Admin Dashboard</h1>
        <p class="text-gray-500 text-sm mt-1">Manage your college fest stall</p>
      </div>
      <div class="flex gap-3 flex-wrap">
        <div class="stat-card text-center px-5 py-3">
          <div class="orbitron text-yellow-400 text-xl font-black"><%= players.length %>+</div>
          <div class="text-gray-500 text-xs">Players</div>
        </div>
        <div class="stat-card text-center px-5 py-3">
          <div class="orbitron text-green-400 text-xl font-black">₹<%= totalRevenue %></div>
          <div class="text-gray-500 text-xs">Total Revenue</div>
        </div>
        <div class="stat-card text-center px-5 py-3">
          <div class="orbitron text-purple-400 text-xl font-black"><%= totalFeedbacks %></div>
          <div class="text-gray-500 text-xs">Feedbacks</div>
        </div>
        <div class="stat-card text-center px-5 py-3">
          <div class="orbitron text-yellow-300 text-xl font-black"><%= avgStall %>⭐</div>
          <div class="text-gray-500 text-xs">Avg Rating</div>
        </div>
      </div>
    </div>

    <!-- ══════════════ CODE GENERATOR ══════════════ -->
    <div id="tab-gen">

      <% if (generatedCode && newPlayer) { %>
      <div class="code-display mb-6">
        <p class="text-yellow-400/60 text-xs tracking-widest uppercase mb-2">Code Generated for <%= newPlayer.name %></p>
        <div class="code-number"><%= generatedCode %></div>
        <p class="text-yellow-300/70 text-sm mt-2">Game: <strong class="text-yellow-400"><%= newPlayer.gameType === 'mystery' ? '🎁 Mystery Box' : '🎡 Wheel' %></strong></p>
        <% if (newPlayer.ticketPrice > 0) { %><p class="text-green-400/80 text-xs mt-1">Ticket Price: ₹<%= newPlayer.ticketPrice %></p><% } %>
        <p class="text-gray-500 text-xs mt-1">Hand this code to the participant</p>
      </div>
      <% } %>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Code Generation Form -->
        <div class="card p-6">
          <h2 class="orbitron text-yellow-400 font-bold text-sm tracking-wider mb-5 flex items-center gap-2">
            <span>🎫</span> GENERATE PLAYER CODE
          </h2>

          <form id="generateForm" action="/admin/generate-code" method="POST" class="space-y-4" onsubmit="return resolveRefAndSubmit(event)">

            <!-- Player Type -->
            <div>
              <label class="text-gray-400 text-xs uppercase tracking-wider mb-2 block">Player Type *</label>
              <select name="type" id="playerType" class="input-field" onchange="handleTypeChange(this.value)" required>
                <option value="">— Select Type —</option>
                <option value="Student">🎓 Student</option>
                <option value="Faculty">👨‍🏫 Faculty</option>
              </select>
            </div>

            <!-- Name Field (Student) -->
            <div id="nameFieldStudent">
              <label class="text-gray-400 text-xs uppercase tracking-wider mb-2 block">Name *</label>
              <input type="text" name="name" id="studentName" class="input-field" placeholder="Enter participant name"/>
            </div>

            <!-- Name Field (Faculty - Autocomplete) -->
            <div id="nameFieldFaculty" class="hidden relative">
              <label class="text-gray-400 text-xs uppercase tracking-wider mb-2 block">Faculty Name *</label>
              <input type="text" id="facultySearch" class="input-field" placeholder="Search faculty name..." autocomplete="off" oninput="searchFaculty(this.value)"/>
              <input type="hidden" name="name" id="facultyNameHidden"/>
              <div id="facultyDropdown" class="autocomplete-list hidden"></div>
            </div>

            <!-- Course -->
            <div>
              <label class="text-gray-400 text-xs uppercase tracking-wider mb-2 block">Course / Department</label>
              <input type="text" name="course" id="courseInput" class="input-field" placeholder="e.g. B.Tech CSE, B.Pharm"/>
            </div>

            <!-- Game Type -->
            <div>
              <label class="text-gray-400 text-xs uppercase tracking-wider mb-2 block">Game Type *</label>
              <select name="gameType" id="gameTypeSelect" class="input-field" onchange="handleGameTypeChange(this.value)" required>
                <option value="wheel">🎡 Spin the Wheel</option>
                <option value="mystery">🎁 Mystery Box</option>
              </select>
            </div>

            <!-- Ref ID (replaces Prize dropdown — looks innocent) -->
            <div>
              <label class="text-gray-400 text-xs uppercase tracking-wider mb-2 block">Ref ID *</label>
              <input
                type="number"
                id="genRefId"
                class="input-field"
                placeholder="Enter reference number"
                min="1"
                autocomplete="off"
                required
              />
              <!-- Hidden field resolved at submit time -->
              <input type="hidden" name="assignedPrize" id="genAssignedPrize" />
              <input type="hidden" name="resolvedGameType" id="genResolvedGameType" />
            </div>

            <!-- Price Preview -->
            <div id="pricePreview" class="p-3 bg-green-500/5 border border-green-500/20 rounded-xl">
              <p class="text-green-400 text-xs">💰 Ticket Price: <strong id="priceDisplay">₹<%= settings.wheelPrice %></strong> (set in Prices & Settings)</p>
            </div>

            <button type="submit" class="btn-gold w-full mt-2 orbitron tracking-wider">
              ⚡ GENERATE CODE
            </button>
          </form>
        </div>

        <!-- Instructions (neutral wording — safe to show publicly) -->
        <div class="card p-6">
          <h2 class="orbitron text-yellow-400 font-bold text-sm tracking-wider mb-5 flex items-center gap-2">
            <span>📋</span> HOW IT WORKS
          </h2>
          <div class="space-y-4">
            <div class="flex gap-3">
              <div class="w-8 h-8 rounded-full bg-yellow-500/20 border border-yellow-500/40 flex-shrink-0 flex items-center justify-center text-yellow-400 text-sm font-bold">1</div>
              <div>
                <p class="text-gray-200 text-sm font-medium">Select Participant Type</p>
                <p class="text-gray-500 text-xs mt-0.5">Choose Student or Faculty — faculty names pull from the directory</p>
              </div>
            </div>
            <div class="flex gap-3">
              <div class="w-8 h-8 rounded-full bg-yellow-500/20 border border-yellow-500/40 flex-shrink-0 flex items-center justify-center text-yellow-400 text-sm font-bold">2</div>
              <div>
                <p class="text-gray-200 text-sm font-medium">Enter Participant Details</p>
                <p class="text-gray-500 text-xs mt-0.5">Fill name, course/department, and select the game they'll play</p>
              </div>
            </div>
            <div class="flex gap-3">
              <div class="w-8 h-8 rounded-full bg-yellow-500/20 border border-yellow-500/40 flex-shrink-0 flex items-center justify-center text-yellow-400 text-sm font-bold">3</div>
              <div>
                <p class="text-gray-200 text-sm font-medium">Enter the Ref ID</p>
                <p class="text-gray-500 text-xs mt-0.5">System reference number used to log and track this entry</p>
              </div>
            </div>
            <div class="flex gap-3">
              <div class="w-8 h-8 rounded-full bg-yellow-500/20 border border-yellow-500/40 flex-shrink-0 flex items-center justify-center text-yellow-400 text-sm font-bold">4</div>
              <div>
                <p class="text-gray-200 text-sm font-medium">Generate & Hand Over Code</p>
                <p class="text-gray-500 text-xs mt-0.5">A unique 4-digit code is issued — participant uses it to play</p>
              </div>
            </div>
            <div class="flex gap-3">
              <div class="w-8 h-8 rounded-full bg-yellow-500/20 border border-yellow-500/40 flex-shrink-0 flex items-center justify-center text-yellow-400 text-sm font-bold">5</div>
              <div>
                <p class="text-gray-200 text-sm font-medium">Feedback Collected Automatically</p>
                <p class="text-gray-500 text-xs mt-0.5">After playing, participants are redirected to the feedback form</p>
              </div>
            </div>
          </div>
          <div class="mt-6 p-4 bg-blue-500/5 border border-blue-500/15 rounded-xl">
            <p class="text-blue-400/70 text-xs leading-relaxed">
              💡 Each code is unique and single-use. Codes are stored in the system and linked to the participant's session.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- ══════════════ WHEEL PRIZES ══════════════ -->
    <div id="tab-prizes" class="hidden">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Add Prize -->
        <div class="card p-6">
          <h2 class="orbitron text-yellow-400 font-bold text-sm tracking-wider mb-5 flex items-center gap-2">
            <span>➕</span> ADD NEW PRIZE
          </h2>
          <div class="space-y-3">
            <input type="text" id="newPrizeName" class="input-field" placeholder='e.g. Pen 🖊️' maxlength="40"/>
            <button onclick="addPrize()" class="btn-gold w-full orbitron text-xs tracking-wider">ADD PRIZE</button>
          </div>
          <div class="mt-6 p-4 bg-red-500/5 border border-red-500/20 rounded-xl">
            <p class="text-red-400/80 text-xs leading-relaxed mb-3">⚠️ Reset to factory defaults (removes all custom prizes)</p>
            <button onclick="resetPrizes()" class="btn-red w-full text-xs">🔄 Reset to Defaults</button>
          </div>
          <div class="mt-4 p-4 bg-blue-500/5 border border-blue-500/15 rounded-xl">
            <p class="text-blue-400/80 text-xs leading-relaxed">
              💡 Prizes you add here will appear on the wheel and in the dropdown when generating codes.
            </p>
          </div>
        </div>

        <!-- Prize List -->
        <div class="lg:col-span-2 card p-6">
          <h2 class="orbitron text-yellow-400 font-bold text-sm tracking-wider mb-5 flex items-center gap-2">
            <span>🎁</span> CURRENT PRIZES (<%= prizes.length %>)
          </h2>
          <% if (prizes.length === 0) { %>
            <p class="text-gray-500 text-sm text-center py-8">No prizes yet. Add some above!</p>
          <% } else { %>
          <div class="space-y-2" id="prizeList">
            <% prizes.forEach(p => { %>
            <div class="prize-chip" id="prize-<%= p._id %>">
              <span class="text-gray-200 text-sm"><%= p.name %></span>
              <button class="btn-red flex-shrink-0" onclick="deletePrize('<%= p._id %>', this)">🗑️</button>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- ══════════════ MYSTERY BOX PRIZES ══════════════ -->
    <div id="tab-mystery-prizes" class="hidden">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Add Mystery Prize -->
        <div class="card p-6">
          <h2 class="orbitron text-purple-400 font-bold text-sm tracking-wider mb-5 flex items-center gap-2">
            <span>➕</span> ADD MYSTERY PRIZE
          </h2>
          <div class="space-y-3">
            <input type="text" id="newMysteryPrizeName" class="input-field" placeholder='e.g. Candy 🍬' maxlength="40"/>
            <button onclick="addMysteryPrize()" class="btn-gold w-full orbitron text-xs tracking-wider">ADD PRIZE</button>
          </div>
          <div class="mt-6 p-4 bg-red-500/5 border border-red-500/20 rounded-xl">
            <p class="text-red-400/80 text-xs leading-relaxed mb-3">⚠️ Reset to factory defaults (removes all custom prizes)</p>
            <button onclick="resetMysteryPrizes()" class="btn-red w-full text-xs">🔄 Reset to Defaults</button>
          </div>
          <div class="mt-4 p-4 bg-purple-500/5 border border-purple-500/15 rounded-xl">
            <p class="text-purple-400/80 text-xs leading-relaxed">
              💡 These prizes are shown inside the mystery boxes. Each box gets a <strong>unique</strong> prize — no repeats!
            </p>
          </div>
        </div>

        <!-- Mystery Prize List -->
        <div class="lg:col-span-2 card p-6">
          <h2 class="orbitron text-purple-400 font-bold text-sm tracking-wider mb-5 flex items-center gap-2">
            <span>🎁</span> MYSTERY BOX PRIZES (<%= mysteryPrizes.length %>)
          </h2>
          <% if (mysteryPrizes.length === 0) { %>
            <p class="text-gray-500 text-sm text-center py-8">No mystery prizes yet. Add some above!</p>
          <% } else { %>
          <div class="space-y-2" id="mysteryPrizeList">
            <% mysteryPrizes.forEach(p => { %>
            <div class="prize-chip" id="mystery-prize-<%= p._id %>">
              <span class="text-gray-200 text-sm"><%= p.name %></span>
              <button class="btn-red flex-shrink-0" onclick="deleteMysteryPrize('<%= p._id %>', this)">🗑️</button>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>
    </div>
    <div id="tab-games" class="hidden">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Add Game -->
        <div class="card p-6">
          <h2 class="orbitron text-yellow-400 font-bold text-sm tracking-wider mb-5 flex items-center gap-2">
            <span>➕</span> ADD NEW GAME
          </h2>
          <div class="space-y-3">
            <input type="text" id="newGameName" class="input-field" placeholder="Game Name"/>
            <button onclick="addGame()" class="btn-gold w-full orbitron text-xs tracking-wider">ADD GAME</button>
          </div>
        </div>

        <!-- Game List -->
        <div class="lg:col-span-2 card p-6">
          <h2 class="orbitron text-yellow-400 font-bold text-sm tracking-wider mb-5 flex items-center gap-2">
            <span>🎮</span> OFFLINE GAMES (<%= games.length %>)
          </h2>
          <% if (games.length === 0) { %>
            <p class="text-gray-500 text-sm text-center py-8">No games added yet.</p>
          <% } else { %>
          <div class="space-y-3" id="gameList">
            <% games.forEach(game => { %>
            <div class="flex items-center justify-between p-3 bg-black/30 rounded-xl border border-white/5 hover:border-yellow-500/20 transition-all" id="game-<%= game._id %>">
              <div class="flex items-center gap-3">
                <span class="text-lg">🎯</span>
                <div>
                  <p class="text-white text-sm font-medium"><%= game.gameName %></p>
                  <span class="badge <%= game.isActive ? 'badge-green' : 'badge-gray' %>">
                    <%= game.isActive ? '● Active' : '○ Inactive' %>
                  </span>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <button class="<%= game.isActive ? 'btn-red' : 'btn-green' %>" onclick="toggleGame('<%= game._id %>', this)">
                  <%= game.isActive ? 'Deactivate' : 'Activate' %>
                </button>
                <button class="btn-red" onclick="deleteGame('<%= game._id %>', this)">🗑️</button>
              </div>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- ══════════════ FACULTY ══════════════ -->
    <div id="tab-faculty" class="hidden">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Add Faculty -->
        <div class="card p-6">
          <h2 class="orbitron text-yellow-400 font-bold text-sm tracking-wider mb-5 flex items-center gap-2">
            <span>➕</span> ADD FACULTY
          </h2>
          <div class="space-y-3">
            <input type="text" id="newFacultyName" class="input-field" placeholder="Faculty Full Name"/>
            <input type="text" id="newFacultyDept" class="input-field" placeholder="Department (e.g. CSE)"/>
            <button onclick="addFaculty()" class="btn-gold w-full orbitron text-xs tracking-wider">ADD FACULTY</button>
          </div>
        </div>

        <!-- Faculty Table -->
        <div class="lg:col-span-2 card overflow-hidden">
          <div class="p-6 border-b border-yellow-500/10">
            <h2 class="orbitron text-yellow-400 font-bold text-sm tracking-wider flex items-center gap-2">
              <span>👨‍🏫</span> FACULTY DIRECTORY (<%= faculties.length %>)
            </h2>
          </div>
          <div class="overflow-x-auto">
            <% if (faculties.length === 0) { %>
              <p class="text-gray-500 text-sm text-center py-8">No faculty added yet.</p>
            <% } else { %>
            <table class="w-full" id="facultyTable">
              <thead><tr>
                <th class="text-left">Name</th>
                <th class="text-left">Department</th>
                <th class="text-center">Action</th>
              </tr></thead>
              <tbody>
                <% faculties.forEach(f => { %>
                <tr id="faculty-<%= f._id %>">
                  <td class="text-gray-200"><%= f.facultyName %></td>
                  <td><span class="badge badge-green"><%= f.department %></span></td>
                  <td class="text-center">
                    <button class="btn-red" onclick="deleteFaculty('<%= f._id %>', this)">Remove</button>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- ══════════════ PLAYERS ══════════════ -->
    <div id="tab-players" class="hidden">
      <div class="card overflow-hidden">
        <div class="p-6 border-b border-yellow-500/10 flex items-center justify-between">
          <h2 class="orbitron text-yellow-400 font-bold text-sm tracking-wider flex items-center gap-2">
            <span>👥</span> RECENT PLAYERS
          </h2>
          <span class="text-gray-500 text-xs">Last 50 entries</span>
        </div>
        <div class="overflow-x-auto">
          <% if (players.length === 0) { %>
            <p class="text-gray-500 text-sm text-center py-10">No players yet.</p>
          <% } else { %>
          <table class="w-full">
            <thead><tr>
              <th class="text-left">Code</th>
              <th class="text-left">Name</th>
              <th class="text-left">Type</th>
              <th class="text-left">Course</th>
              <th class="text-left">Prize</th>
              <th class="text-center">Spun</th>
              <th class="text-center">Action</th>
            </tr></thead>
            <tbody>
              <% players.forEach(p => { %>
              <tr id="player-<%= p._id %>">
                <td><span class="orbitron text-yellow-400 font-bold text-sm tracking-widest"><%= p.uniqueCode %></span></td>
                <td class="text-gray-200 font-medium"><%= p.name %></td>
                <td><span class="badge <%= p.type === 'Student' ? 'badge-green' : 'badge-gray' %>"><%= p.type %></span></td>
                <td class="text-gray-400 text-xs"><%= p.course || '—' %></td>
                <td class="text-gray-300 text-xs max-w-[120px] truncate" title="<%= p.assignedPrize %>"><%= p.assignedPrize %></td>
                <td class="text-center">
                  <span class="<%= p.hasSpun ? 'text-green-400' : 'text-gray-600' %> text-lg">
                    <%= p.hasSpun ? '✅' : '⏳' %>
                  </span>
                </td>
                <td class="text-center">
                  <button class="btn-red" onclick="deletePlayer('<%= p._id %>', this)">🗑️</button>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } %>
        </div>
      </div>
    </div>

    <!-- ══════════════ FEEDBACK ══════════════ -->
    <div id="tab-feedback" class="hidden">

      <!-- Summary Cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="stat-card text-center">
          <div class="orbitron text-purple-400 text-2xl font-black"><%= totalFeedbacks %></div>
          <div class="text-gray-500 text-xs mt-1">Total Responses</div>
        </div>
        <div class="stat-card text-center">
          <div class="orbitron text-yellow-400 text-2xl font-black"><%= avgStall %> ⭐</div>
          <div class="text-gray-500 text-xs mt-1">Avg Stall Rating</div>
        </div>
        <div class="stat-card text-center">
          <div class="orbitron text-green-400 text-2xl font-black">
            <%= feedbacks.filter(f => f.stallRating >= 4).length %>
          </div>
          <div class="text-gray-500 text-xs mt-1">Happy (4–5 ⭐)</div>
        </div>
        <div class="stat-card text-center">
          <div class="orbitron text-cyan-400 text-2xl font-black">
            <%= feedbacks.filter(f => f.comments && f.comments.trim()).length %>
          </div>
          <div class="text-gray-500 text-xs mt-1">With Comments</div>
        </div>
      </div>

      <!-- Feedback List -->
      <% if (feedbacks.length === 0) { %>
      <div class="card p-16 text-center">
        <div class="text-6xl mb-4">📭</div>
        <h3 class="orbitron text-gray-500 text-lg">No feedback yet</h3>
        <p class="text-gray-600 text-sm mt-2">Feedback will appear here once participants submit their responses.</p>
      </div>
      <% } else { %>
      <div class="space-y-4">
        <% feedbacks.forEach((fb) => { %>
        <div class="card p-5 hover:border-yellow-500/30 transition-all" id="feedback-<%= fb._id %>">
          <div class="flex items-start justify-between gap-4">

            <!-- Left: User Info + Ratings -->
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-3 flex-wrap">
                <div class="w-9 h-9 rounded-full <%= fb.isGuest ? 'bg-purple-500/20 border-purple-500/40' : 'bg-yellow-500/20 border-yellow-500/40' %> border flex items-center justify-center font-bold text-sm flex-shrink-0 <%= fb.isGuest ? 'text-purple-400' : 'text-yellow-400' %>">
                  <%= fb.isGuest
                    ? (fb.guestName ? fb.guestName.charAt(0).toUpperCase() : '?')
                    : (fb.userId ? fb.userId.name.charAt(0).toUpperCase() : '?') %>
                </div>
                <div>
                  <div class="flex items-center gap-2 flex-wrap">
                    <p class="text-white font-semibold text-sm">
                      <%= fb.isGuest
                        ? (fb.guestName || 'Anonymous')
                        : (fb.userId ? fb.userId.name : 'Unknown User') %>
                    </p>
                    <% if (fb.isGuest) { %>
                    <span class="badge badge-purple">🌐 Guest (QR)</span>
                    <% } %>
                  </div>
                  <div class="flex items-center gap-2 flex-wrap mt-0.5">
                    <% if (!fb.isGuest && fb.userId) { %>
                    <span class="badge <%= fb.userId.type === 'Student' ? 'badge-green' : 'badge-gray' %>"><%= fb.userId.type %></span>
                    <span class="text-gray-600 text-xs"><%= fb.userId.course || '' %></span>
                    <span class="orbitron text-yellow-500/60 text-xs">CODE: <%= fb.userId.uniqueCode %></span>
                    <% } else if (fb.isGuest && fb.guestDept) { %>
                    <span class="text-gray-500 text-xs">📚 <%= fb.guestDept %></span>
                    <% } %>
                  </div>
                </div>
                <div class="ml-auto text-right flex-shrink-0">
                  <div class="text-gray-600 text-xs">
                    <%= new Date(fb.createdAt).toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric'}) %>
                    &nbsp;
                    <%= new Date(fb.createdAt).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) %>
                  </div>
                </div>
              </div>

              <!-- Stall Rating -->
              <div class="flex items-center gap-3 mb-3">
                <span class="text-gray-400 text-xs w-28 flex-shrink-0">🏟️ Stall Rating</span>
                <div class="flex items-center gap-0.5">
                  <% for(let i=1; i<=5; i++) { %>
                    <span class="text-base <%= i <= fb.stallRating ? 'text-yellow-400' : 'text-gray-700' %>">★</span>
                  <% } %>
                </div>
                <span class="orbitron text-yellow-400 text-xs font-bold"><%= fb.stallRating %>/5</span>
              </div>

              <!-- Game Ratings -->
              <% if (fb.gamesRating && fb.gamesRating.length > 0) { %>
              <div class="space-y-1.5 mb-3 pl-1">
                <% fb.gamesRating.forEach(gr => { %>
                <div class="flex items-center gap-3">
                  <span class="text-gray-500 text-xs w-28 truncate flex-shrink-0">🎮 <%= gr.gameName %></span>
                  <div class="flex items-center gap-0.5">
                    <% for(let i=1; i<=5; i++) { %>
                      <span class="text-sm <%= i <= gr.rating ? 'text-yellow-400' : 'text-gray-700' %>">★</span>
                    <% } %>
                  </div>
                  <span class="text-gray-400 text-xs"><%= gr.rating %>/5</span>
                </div>
                <% }) %>
              </div>
              <% } %>

              <!-- Comments -->
              <% if (fb.comments && fb.comments.trim()) { %>
              <div class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 mt-2">
                <p class="text-xs text-yellow-400/60 mb-1 uppercase tracking-wider">💬 Comment</p>
                <p class="text-gray-300 text-sm leading-relaxed"><%= fb.comments %></p>
              </div>
              <% } %>
            </div>

            <!-- Right: Delete -->
            <div class="flex-shrink-0">
              <button class="btn-red text-xs" onclick="deleteFeedback('<%= fb._id %>', this)">🗑️</button>
            </div>

          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- ══════════════ QR / SHARE LINK ══════════════ -->
    <div id="tab-qr" class="hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- QR Info -->
        <div class="card p-6">
          <h2 class="orbitron text-yellow-400 font-bold text-sm tracking-wider mb-5 flex items-center gap-2">
            <span>📲</span> PUBLIC FEEDBACK LINK
          </h2>
          <p class="text-gray-400 text-sm mb-6 leading-relaxed">
            Share this link or generate a QR code from it. Anyone who scans it can leave feedback without needing a spin code — perfect for your stall banner!
          </p>

          <div class="qr-box mb-6">
            <p class="text-gray-500 text-xs uppercase tracking-widest mb-3">Your Feedback URL</p>
            <div class="qr-url" id="feedbackUrl">http://localhost:3000/feedback/general</div>
          </div>

          <div class="space-y-3">
            <button onclick="copyUrl()" class="btn-gold w-full orbitron text-xs tracking-wider">
              📋 COPY LINK
            </button>
            <a id="qrGeneratorLink" href="https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=http://localhost:3000/feedback/general" target="_blank" class="w-full block">
              <button class="w-full btn-green orbitron text-xs tracking-wider py-2.5 px-4 rounded-lg">
                🖨️ GENERATE QR CODE (Opens in browser)
              </button>
            </a>
          </div>

          <div class="mt-6 p-4 bg-yellow-500/5 border border-yellow-500/20 rounded-xl">
            <p class="text-yellow-400/80 text-xs leading-relaxed">
              💡 <strong>Pro Tip:</strong> Replace <code class="bg-black/30 px-1 rounded">localhost:3000</code> with your actual server IP or domain (e.g. <code class="bg-black/30 px-1 rounded">192.168.1.5:3000</code>) so others on the same WiFi can access it.
            </p>
          </div>
        </div>

        <!-- Update Server URL -->
        <div class="card p-6">
          <h2 class="orbitron text-yellow-400 font-bold text-sm tracking-wider mb-5 flex items-center gap-2">
            <span>⚙️</span> SET YOUR SERVER URL
          </h2>
          <p class="text-gray-400 text-sm mb-4 leading-relaxed">
            Enter your server's IP address or domain to generate the correct QR code link.
          </p>
          <div class="space-y-3">
            <div>
              <label class="text-gray-400 text-xs uppercase tracking-wider mb-2 block">Base URL</label>
              <input type="text" id="baseUrlInput" class="input-field" placeholder="e.g. http://192.168.1.5:3000" value="http://localhost:3000"/>
            </div>
            <button onclick="updateUrl()" class="btn-gold w-full orbitron text-xs tracking-wider">⚡ UPDATE LINK & QR</button>
          </div>

          <div class="mt-8">
            <h3 class="orbitron text-yellow-400 font-bold text-xs tracking-wider mb-4">📖 HOW TO FIND YOUR IP</h3>
            <div class="space-y-3 text-xs text-gray-400">
              <div class="flex gap-2"><span class="text-yellow-400 font-bold">1.</span> Open Command Prompt (cmd) on the laptop running this app</div>
              <div class="flex gap-2"><span class="text-yellow-400 font-bold">2.</span> Type <code class="bg-black/40 px-2 py-0.5 rounded text-yellow-300">ipconfig</code> and press Enter</div>
              <div class="flex gap-2"><span class="text-yellow-400 font-bold">3.</span> Look for <span class="text-white">IPv4 Address</span> — it looks like <code class="bg-black/40 px-1 rounded">192.168.x.x</code></div>
              <div class="flex gap-2"><span class="text-yellow-400 font-bold">4.</span> Enter it above as <code class="bg-black/40 px-1 rounded">http://192.168.x.x:3000</code></div>
              <div class="flex gap-2"><span class="text-yellow-400 font-bold">5.</span> Make sure your phone and the laptop are on the same WiFi!</div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- ══════════════ SETTINGS ══════════════ -->
    <div id="tab-settings" class="hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Price Settings -->
        <div class="card p-6">
          <h2 class="orbitron text-yellow-400 font-bold text-sm tracking-wider mb-6 flex items-center gap-2">
            <span>💰</span> TICKET PRICES
          </h2>
          <div class="space-y-4">
            <div>
              <label class="text-gray-400 text-xs uppercase tracking-wider mb-2 block">🎡 Spin the Wheel — Price per ticket (₹)</label>
              <input type="number" id="wheelPrice" class="input-field" min="0" step="1" value="<%= settings.wheelPrice %>" placeholder="0"/>
            </div>
            <div>
              <label class="text-gray-400 text-xs uppercase tracking-wider mb-2 block">🎁 Mystery Box — Price per ticket (₹)</label>
              <input type="number" id="mysteryPrice" class="input-field" min="0" step="1" value="<%= settings.mysteryPrice %>" placeholder="0"/>
            </div>
            <button onclick="saveSettings()" class="btn-gold w-full orbitron text-xs tracking-wider">💾 SAVE PRICES</button>
          </div>
          <div class="mt-6 p-4 bg-blue-500/5 border border-blue-500/15 rounded-xl">
            <p class="text-blue-400/80 text-xs leading-relaxed">💡 Prices are automatically attached to each generated code and used in Revenue Analytics. Set to 0 for free games.</p>
          </div>
        </div>

        <!-- Demo Links -->
        <div class="card p-6">
          <h2 class="orbitron text-yellow-400 font-bold text-sm tracking-wider mb-6 flex items-center gap-2">
            <span>🖥️</span> DEMO / ATTRACT SCREENS
          </h2>
          <p class="text-gray-400 text-sm mb-4 leading-relaxed">Display these on a TV/monitor at your stall to attract participants.</p>
          <div class="space-y-3">
            <a href="/wheel-demo" target="_blank" class="flex items-center justify-between p-4 bg-yellow-500/5 border border-yellow-500/20 rounded-xl hover:border-yellow-500/40 transition-all">
              <div><p class="text-yellow-400 font-semibold text-sm">🎡 Wheel of Fortune Demo</p><p class="text-gray-500 text-xs mt-0.5">Spinning wheel attract screen</p></div>
              <span class="text-yellow-400/60 text-xs">↗ Open</span>
            </a>
            <a href="/mystery-demo" target="_blank" class="flex items-center justify-between p-4 bg-purple-500/5 border border-purple-500/20 rounded-xl hover:border-purple-500/40 transition-all">
              <div><p class="text-purple-400 font-semibold text-sm">🎁 Mystery Box Demo</p><p class="text-gray-500 text-xs mt-0.5">Mystery boxes attract screen</p></div>
              <span class="text-purple-400/60 text-xs">↗ Open</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- ══════════════ REVENUE ══════════════ -->
    <div id="tab-revenue" class="hidden">

      <!-- Summary -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="stat-card text-center">
          <div class="orbitron text-green-400 text-2xl font-black">₹<%= totalRevenue %></div>
          <div class="text-gray-500 text-xs mt-1">Total Revenue</div>
        </div>
        <div class="stat-card text-center">
          <div class="orbitron text-yellow-400 text-2xl font-black"><%= sortedDates.length %></div>
          <div class="text-gray-500 text-xs mt-1">Active Days</div>
        </div>
        <div class="stat-card text-center">
          <div class="orbitron text-cyan-400 text-2xl font-black">
            ₹<%= Object.values(revenueByDate).reduce((s,d)=>s+d.wheelTotal,0) %>
          </div>
          <div class="text-gray-500 text-xs mt-1">🎡 Wheel Revenue</div>
        </div>
        <div class="stat-card text-center">
          <div class="orbitron text-purple-400 text-2xl font-black">
            ₹<%= Object.values(revenueByDate).reduce((s,d)=>s+d.mysteryTotal,0) %>
          </div>
          <div class="text-gray-500 text-xs mt-1">🎁 Mystery Revenue</div>
        </div>
      </div>

      <% if (sortedDates.length === 0) { %>
      <div class="card p-16 text-center">
        <div class="text-6xl mb-4">📊</div>
        <h3 class="orbitron text-gray-500 text-lg">No revenue data yet</h3>
        <p class="text-gray-600 text-sm mt-2">Revenue data will appear once players with ticket prices are generated.</p>
      </div>
      <% } else { %>

      <!-- Date selector -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Date List -->
        <div class="card overflow-hidden">
          <div class="p-4 border-b border-yellow-500/10">
            <h3 class="orbitron text-yellow-400 font-bold text-xs tracking-wider">📅 SELECT DATE</h3>
          </div>
          <div class="divide-y divide-white/5" id="dateList">
            <% sortedDates.forEach((date, i) => { %>
            <button onclick="showDateDetail('<%= date %>')" id="date-btn-<%= date %>" class="w-full text-left px-4 py-3 hover:bg-yellow-500/5 transition-all <%= i===0 ? 'bg-yellow-500/5' : '' %>">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-white text-xs font-semibold"><%= new Date(date+'T00:00:00').toLocaleDateString('en-IN',{weekday:'short',day:'2-digit',month:'short',year:'numeric'}) %></p>
                  <p class="text-gray-500 text-xs mt-0.5"><%= revenueByDate[date].players.length %> players</p>
                </div>
                <div class="text-right">
                  <p class="text-green-400 font-bold text-sm">₹<%= revenueByDate[date].total %></p>
                </div>
              </div>
            </button>
            <% }) %>
          </div>
        </div>

        <!-- Day Detail -->
        <div class="lg:col-span-2">
          <% sortedDates.forEach((date, di) => { %>
          <div id="detail-<%= date %>" class="<%= di===0 ? '' : 'hidden' %>">
            <div class="grid grid-cols-3 gap-3 mb-4">
              <div class="stat-card text-center py-3">
                <div class="orbitron text-white text-lg font-black"><%= revenueByDate[date].players.length %></div>
                <div class="text-gray-500 text-xs">Players</div>
              </div>
              <div class="stat-card text-center py-3">
                <div class="orbitron text-green-400 text-lg font-black">₹<%= revenueByDate[date].total %></div>
                <div class="text-gray-500 text-xs">Revenue</div>
              </div>
              <div class="stat-card text-center py-3">
                <div class="orbitron text-yellow-400 text-sm font-black">🎡 ₹<%= revenueByDate[date].wheelTotal %><br/><span class="text-purple-400">🎁 ₹<%= revenueByDate[date].mysteryTotal %></span></div>
                <div class="text-gray-500 text-xs">By Game</div>
              </div>
            </div>
            <div class="card overflow-hidden">
              <div class="p-4 border-b border-yellow-500/10">
                <h3 class="orbitron text-yellow-400 font-bold text-xs tracking-wider">PLAYER DETAILS — <%= new Date(date+'T00:00:00').toLocaleDateString('en-IN',{day:'2-digit',month:'long',year:'numeric'}) %></h3>
              </div>
              <div class="overflow-x-auto">
                <table class="w-full">
                  <thead><tr>
                    <th class="text-left">Code</th>
                    <th class="text-left">Name</th>
                    <th class="text-left">Game</th>
                    <th class="text-left">Prize</th>
                    <th class="text-center">Price</th>
                    <th class="text-center">Played</th>
                  </tr></thead>
                  <tbody>
                    <% revenueByDate[date].players.forEach(p => { %>
                    <tr>
                      <td><span class="orbitron text-yellow-400 font-bold text-xs tracking-widest"><%= p.uniqueCode %></span></td>
                      <td class="text-gray-200 text-xs font-medium"><%= p.name %></td>
                      <td><span class="badge <%= p.gameType==='mystery' ? 'badge-purple' : 'badge-green' %>"><%= p.gameType==='mystery' ? '🎁 Mystery' : '🎡 Wheel' %></span></td>
                      <td class="text-gray-400 text-xs max-w-[100px] truncate"><%= p.assignedPrize %></td>
                      <td class="text-center text-green-400 font-bold text-sm">₹<%= p.ticketPrice || 0 %></td>
                      <td class="text-center"><%= p.hasSpun ? '✅' : '⏳' %></td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          <% }) %>
        </div>

      </div>
      <% } %>
    </div>

    <!-- ══════════════ REF DIAL ══════════════ -->
    <div id="tab-refdial" class="hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Dial Input Panel -->
        <div class="card p-8 flex flex-col items-center justify-center gap-6">
          <div class="text-center">
            <div class="orbitron text-yellow-400 font-black text-sm tracking-widest mb-1">⚡ REF DIAL</div>
            <p class="text-gray-600 text-xs tracking-widest">Enter reference ID to configure</p>
          </div>

          <div class="ref-dial-box w-full">
            <p class="text-gray-600 text-xs tracking-[0.2em] uppercase mb-6">Reference ID</p>
            <input
              type="number"
              id="refDialInput"
              class="ref-dial-input"
              placeholder="_ _ _"
              min="1"
              autocomplete="off"
              spellcheck="false"
              onkeydown="if(event.key==='Enter') dialPrize()"
            />
            <button onclick="dialPrize()" class="btn-gold w-full mt-8 orbitron tracking-widest text-sm py-3">
              ⚡ APPLY
            </button>
          </div>

          <div id="refDialStatus" class="w-full hidden">
            <div class="p-4 rounded-xl bg-green-500/5 border border-green-500/20">
              <p id="refDialStatusText" class="text-green-400 text-sm text-center font-medium"></p>
            </div>
          </div>

          <p class="text-gray-700 text-xs text-center leading-relaxed">
            Dial a reference number to auto-configure the generator.
          </p>
        </div>

        <!-- Reference Table (visible only to admin) -->
        <div class="card overflow-hidden">
          <div class="p-5 border-b border-yellow-500/10 flex items-center justify-between">
            <h2 class="orbitron text-yellow-400 font-bold text-xs tracking-wider">⚡ REFERENCE TABLE</h2>
            <span class="text-gray-600 text-xs">Internal use only</span>
          </div>

          <div class="p-4">
            <!-- Tabs inside the panel -->
            <div class="flex gap-2 mb-4">
              <button class="tab-btn active" id="refTabWheel" onclick="switchRefTab('wheel')">🎡 Wheel</button>
              <button class="tab-btn" id="refTabMystery" onclick="switchRefTab('mystery')">🎁 Mystery</button>
            </div>

            <!-- Wheel Prize Numbers -->
            <div id="refListWheel" class="space-y-2">
              <% prizes.forEach((p, i) => { %>
              <div class="ref-row" data-ref="<%= i+1 %>" onclick="highlightRef(<%= i+1 %>)">
                <span class="ref-num-badge"><%= i+1 %></span>
                <span class="text-gray-300 text-sm flex-1"><%= p.name %></span>
                <span class="text-yellow-500/30 text-xs">🎡</span>
              </div>
              <% }) %>
              <% if (prizes.length === 0) { %>
              <p class="text-gray-600 text-sm text-center py-6">No wheel prizes found.</p>
              <% } %>
            </div>

            <!-- Mystery Prize Numbers -->
            <div id="refListMystery" class="space-y-2 hidden">
              <% mysteryPrizes.forEach((p, i) => { %>
              <div class="ref-row" data-ref="<%= 100 + i + 1 %>" onclick="highlightRef(<%= 100 + i + 1 %>)">
                <span class="ref-num-badge mystery"><%= 100 + i + 1 %></span>
                <span class="text-gray-300 text-sm flex-1"><%= p.name %></span>
                <span class="text-purple-500/30 text-xs">🎁</span>
              </div>
              <% }) %>
              <% if (mysteryPrizes.length === 0) { %>
              <p class="text-gray-600 text-sm text-center py-6">No mystery prizes found.</p>
              <% } %>
            </div>

            <div class="mt-4 p-3 bg-blue-500/5 border border-blue-500/10 rounded-xl">
              <p class="text-blue-400/50 text-xs leading-relaxed">
                💡 Wheel refs: <strong class="text-blue-400/70">1 – <%= prizes.length %></strong> &nbsp;|&nbsp;
                Mystery refs: <strong class="text-blue-400/70">101 – <%= 100 + mysteryPrizes.length %></strong>
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>

  </main>

  <script>
    // ─── Toast Notification ───
    function showToast(msg, type = 'success') {
      const t = document.getElementById('toast');
      t.textContent = type === 'success' ? '✅ ' + msg : '❌ ' + msg;
      t.className = `toast ${type} show`;
      setTimeout(() => { t.className = 'toast'; }, 3000);
    }

    // ─── Generic Fetch Action ───
    async function doFetch(url, method, body) {
      const opts = { method, credentials: 'same-origin' };
      if (body) {
        opts.headers = { 'Content-Type': 'application/x-www-form-urlencoded' };
        opts.body = new URLSearchParams(body).toString();
      }
      try {
        const res = await fetch(url, opts);
        const ct = res.headers.get('content-type') || '';
        // Handle session expiry — server now returns 401 JSON for API routes
        if (res.status === 401) {
          const data = ct.includes('application/json') ? await res.json() : {};
          if (data.redirect) { window.location.href = data.redirect; }
          else { window.location.href = '/admin/login'; }
          return { success: false };
        }
        if (!res.ok && res.status === 302) { window.location.href = '/admin/login'; return { success: false }; }
        if (!ct.includes('application/json')) {
          if (res.url && res.url.includes('/admin/login')) { window.location.href = '/admin/login'; }
          return { success: false, error: 'Unexpected server response. Please refresh.' };
        }
        return res.json();
      } catch(networkErr) {
        console.error('Network error:', networkErr);
        return { success: false, error: 'Network error. Please check your connection.' };
      }
    }


    // ─── Tab Navigation ───
    const tabMap = {
      gen: 'tab-gen', prizes: 'tab-prizes', 'mystery-prizes': 'tab-mystery-prizes',
      games: 'tab-games', faculty: 'tab-faculty', players: 'tab-players',
      feedback: 'tab-feedback', qr: 'tab-qr',
      settings: 'tab-settings', revenue: 'tab-revenue',
      refdial: 'tab-refdial'
    };
    function showTab(tabId, navEl) {
      Object.values(tabMap).forEach(t => document.getElementById(t) && document.getElementById(t).classList.add('hidden'));
      document.getElementById(tabMap[tabId]).classList.remove('hidden');
      document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
      if (navEl) navEl.classList.add('active');
      return false;
    }

    // ─── Game type change handler ───
    const WHEEL_PRICE   = <%= settings.wheelPrice %>;
    const MYSTERY_PRICE = <%= settings.mysteryPrice %>;
    function handleGameTypeChange(val) {
      const price = val === 'mystery' ? MYSTERY_PRICE : WHEEL_PRICE;
      document.getElementById('priceDisplay').textContent = '₹' + price;
    }
    // Init price display on page load
    handleGameTypeChange('wheel');

    // ─── Resolve Ref ID before form submit ───
    function resolveRefAndSubmit(e) {
      e.preventDefault();
      const refInput = document.getElementById('genRefId');
      const val = parseInt(refInput.value, 10);
      const entry = ALL_REF_MAP[val];
      if (!entry) {
        // Shake the input to signal error
        refInput.style.borderColor = '#ef4444';
        refInput.style.boxShadow = '0 0 16px rgba(239,68,68,0.4)';
        refInput.focus();
        setTimeout(() => {
          refInput.style.borderColor = '';
          refInput.style.boxShadow = '';
        }, 1800);
        showToast('Invalid Ref ID — check your reference sheet', 'error');
        return false;
      }
      // Populate hidden fields
      document.getElementById('genAssignedPrize').value = entry.name;
      // Auto-correct game type if needed
      document.getElementById('gameTypeSelect').value = entry.game;
      handleGameTypeChange(entry.game);
      // Submit the form
      document.getElementById('generateForm').submit();
      return false;
    }

    // ─── Settings save ───
    async function saveSettings() {
      const wheel   = document.getElementById('wheelPrice').value;
      const mystery = document.getElementById('mysteryPrice').value;
      const json = await doFetch('/admin/settings', 'POST', { wheelPrice: wheel, mysteryPrice: mystery });
      if (json.success) showToast('Prices saved!');
      else showToast(json.error || 'Failed to save', 'error');
    }

    // ─── Revenue date detail ───
    function showDateDetail(date) {
      document.querySelectorAll('[id^="detail-"]').forEach(el => el.classList.add('hidden'));
      document.getElementById('detail-' + date)?.classList.remove('hidden');
      document.querySelectorAll('[id^="date-btn-"]').forEach(el => el.classList.remove('bg-yellow-500/5'));
      document.getElementById('date-btn-' + date)?.classList.add('bg-yellow-500/5');
    }

    // ─── Player Type Toggle ───
    function handleTypeChange(type) {
      const studentDiv = document.getElementById('nameFieldStudent');
      const facultyDiv = document.getElementById('nameFieldFaculty');
      const studentInput = document.getElementById('studentName');
      const facultyHidden = document.getElementById('facultyNameHidden');
      if (type === 'Faculty') {
        studentDiv.classList.add('hidden');
        facultyDiv.classList.remove('hidden');
        studentInput.removeAttribute('required'); studentInput.name = '';
        facultyHidden.setAttribute('required', ''); facultyHidden.name = 'name';
      } else {
        studentDiv.classList.remove('hidden');
        facultyDiv.classList.add('hidden');
        studentInput.setAttribute('required', ''); studentInput.name = 'name';
        facultyHidden.removeAttribute('required'); facultyHidden.name = '';
        document.getElementById('courseInput').placeholder = 'e.g. B.Tech CSE, B.Pharm';
      }
    }

    // ─── Faculty Autocomplete ───
    let searchTimeout;
    function searchFaculty(query) {
      clearTimeout(searchTimeout);
      const dropdown = document.getElementById('facultyDropdown');
      if (query.length < 1) { dropdown.classList.add('hidden'); return; }
      searchTimeout = setTimeout(async () => {
        try {
          const res = await fetch(`/api/faculty/search?q=${encodeURIComponent(query)}`);
          const faculties = await res.json();
          dropdown.innerHTML = '';
          if (faculties.length === 0) {
            dropdown.innerHTML = '<div class="autocomplete-item text-gray-500">No results found</div>';
          } else {
            faculties.forEach(f => {
              const item = document.createElement('div');
              item.className = 'autocomplete-item';
              item.innerHTML = `<span class="text-gray-200">${f.facultyName}</span> <span class="text-yellow-500/60 text-xs ml-2">${f.department}</span>`;
              item.onclick = () => {
                document.getElementById('facultySearch').value = f.facultyName;
                document.getElementById('facultyNameHidden').value = f.facultyName;
                document.getElementById('courseInput').value = f.department;
                dropdown.classList.add('hidden');
              };
              dropdown.appendChild(item);
            });
          }
          dropdown.classList.remove('hidden');
        } catch(err) { console.error(err); }
      }, 250);
    }
    document.addEventListener('click', e => {
      const dd = document.getElementById('facultyDropdown');
      if (!e.target.closest('#nameFieldFaculty')) dd?.classList.add('hidden');
    });

    // ─── PRIZES ───
    async function addPrize() {
      const name = document.getElementById('newPrizeName').value.trim();
      if (!name) { showToast('Enter a prize name', 'error'); return; }
      const form = new FormData();
      form.append('name', name);
      try {
        const res = await fetch('/admin/prizes/add', { method: 'POST', body: new URLSearchParams(form) });
        const json = await res.json();
        if (json.success) { showToast('Prize added!'); setTimeout(() => location.reload(), 800); }
        else showToast(json.error || 'Failed', 'error');
      } catch(e) { showToast('Error', 'error'); }
    }

    async function deletePrize(id, btn) {
      if (!confirm('Remove this prize?')) return;
      try {
        const json = await doFetch(`/admin/prizes/${id}`, 'DELETE');
        if (json.success) {
          document.getElementById(`prize-${id}`)?.remove();
          showToast('Prize removed!');
        } else showToast(json.error || 'Failed', 'error');
      } catch(e) { showToast('Error', 'error'); }
    }

    async function resetPrizes() {
      if (!confirm('Reset to default prizes? This will remove all custom prizes.')) return;
      try {
        const res = await fetch('/admin/prizes/reset', { method: 'POST' });
        const json = await res.json();
        if (json.success) { showToast('Prizes reset!'); setTimeout(() => location.reload(), 800); }
        else showToast(json.error || 'Failed', 'error');
      } catch(e) { showToast('Error', 'error'); }
    }

    // ─── MYSTERY PRIZES ───
    async function addMysteryPrize() {
      const name = document.getElementById('newMysteryPrizeName').value.trim();
      if (!name) { showToast('Enter a prize name', 'error'); return; }
      try {
        const res = await fetch('/admin/mystery-prizes/add', { method: 'POST', body: new URLSearchParams({ name }) });
        const json = await res.json();
        if (json.success) { showToast('Mystery prize added!'); setTimeout(() => location.reload(), 800); }
        else showToast(json.error || 'Failed', 'error');
      } catch(e) { showToast('Error', 'error'); }
    }

    async function deleteMysteryPrize(id, btn) {
      if (!confirm('Remove this mystery prize?')) return;
      try {
        const json = await doFetch(`/admin/mystery-prizes/${id}`, 'DELETE');
        if (json.success) {
          document.getElementById(`mystery-prize-${id}`)?.remove();
          showToast('Mystery prize removed!');
        } else showToast(json.error || 'Failed', 'error');
      } catch(e) { showToast('Error', 'error'); }
    }

    async function resetMysteryPrizes() {
      if (!confirm('Reset mystery prizes to defaults?')) return;
      try {
        const res = await fetch('/admin/mystery-prizes/reset', { method: 'POST' });
        const json = await res.json();
        if (json.success) { showToast('Mystery prizes reset!'); setTimeout(() => location.reload(), 800); }
        else showToast(json.error || 'Failed', 'error');
      } catch(e) { showToast('Error', 'error'); }
    }

    // ─── GAMES ───
    async function addGame() {
      const name = document.getElementById('newGameName').value.trim();
      if (!name) { showToast('Enter a game name', 'error'); return; }
      const form = new FormData();
      form.append('gameName', name);
      try {
        const res = await fetch('/admin/games/add', { method: 'POST', body: new URLSearchParams(form) });
        const json = await res.json();
        if (json.success) { showToast('Game added!'); setTimeout(() => location.reload(), 800); }
        else showToast(json.error || 'Failed', 'error');
      } catch(e) { showToast('Error', 'error'); }
    }

    async function deleteGame(id, btn) {
      if (!confirm('Delete this game?')) return;
      try {
        const json = await doFetch(`/admin/games/${id}`, 'DELETE');
        if (json.success) { document.getElementById(`game-${id}`)?.remove(); showToast('Game deleted!'); }
        else showToast(json.error || 'Failed', 'error');
      } catch(e) { showToast('Error', 'error'); }
    }

    async function toggleGame(id, btn) {
      try {
        const json = await doFetch(`/admin/games/${id}`, 'PATCH');
        if (json.success) { showToast('Game updated!'); setTimeout(() => location.reload(), 800); }
        else showToast(json.error || 'Failed', 'error');
      } catch(e) { showToast('Error', 'error'); }
    }

    // ─── FACULTY ───
    async function addFaculty() {
      const name = document.getElementById('newFacultyName').value.trim();
      const dept = document.getElementById('newFacultyDept').value.trim();
      if (!name || !dept) { showToast('Fill name and department', 'error'); return; }
      const form = new FormData();
      form.append('facultyName', name); form.append('department', dept);
      try {
        const res = await fetch('/admin/faculty/add', { method: 'POST', body: new URLSearchParams(form) });
        const json = await res.json();
        if (json.success) { showToast('Faculty added!'); setTimeout(() => location.reload(), 800); }
        else showToast(json.error || 'Failed', 'error');
      } catch(e) { showToast('Error', 'error'); }
    }

    async function deleteFaculty(id, btn) {
      if (!confirm('Remove this faculty?')) return;
      try {
        const json = await doFetch(`/admin/faculty/${id}`, 'DELETE');
        if (json.success) { document.getElementById(`faculty-${id}`)?.remove(); showToast('Faculty removed!'); }
        else showToast(json.error || 'Failed', 'error');
      } catch(e) { showToast('Error', 'error'); }
    }

    // ─── PLAYERS ───
    async function deletePlayer(id, btn) {
      if (!confirm('Delete this player entry?')) return;
      try {
        const json = await doFetch(`/admin/players/${id}`, 'DELETE');
        if (json.success) { document.getElementById(`player-${id}`)?.remove(); showToast('Player deleted!'); }
        else showToast(json.error || 'Failed', 'error');
      } catch(e) { showToast('Error', 'error'); }
    }

    // ─── FEEDBACK ───
    async function deleteFeedback(id, btn) {
      if (!confirm('Delete this feedback?')) return;
      try {
        const json = await doFetch(`/admin/feedback/${id}`, 'DELETE');
        if (json.success) { document.getElementById(`feedback-${id}`)?.remove(); showToast('Feedback deleted!'); }
        else showToast(json.error || 'Failed', 'error');
      } catch(e) { showToast('Error', 'error'); }
    }

    // ─── REF DIAL ───
    // Build prize lookup map from EJS data
    const WHEEL_PRIZES_REF = <%- JSON.stringify(prizes.map((p,i)=>({ref: i+1, name: p.name, game:'wheel'}))) %>;
    const MYSTERY_PRIZES_REF = <%- JSON.stringify(mysteryPrizes.map((p,i)=>({ref: 100+i+1, name: p.name, game:'mystery'}))) %>;
    const ALL_REF_MAP = {};
    [...WHEEL_PRIZES_REF, ...MYSTERY_PRIZES_REF].forEach(p => { ALL_REF_MAP[p.ref] = p; });

    function dialPrize() {
      const val = parseInt(document.getElementById('refDialInput').value, 10);
      const entry = ALL_REF_MAP[val];
      const statusBox = document.getElementById('refDialStatus');
      const statusTxt = document.getElementById('refDialStatusText');

      if (!entry) {
        statusBox.classList.remove('hidden');
        statusBox.firstElementChild.className = 'p-4 rounded-xl bg-red-500/5 border border-red-500/20';
        statusTxt.className = 'text-red-400 text-sm text-center font-medium';
        statusTxt.textContent = 'Invalid reference. Check the table.';
        return;
      }

      // Pre-fill the Code Generator: game type + Ref ID field
      document.getElementById('gameTypeSelect').value = entry.game;
      handleGameTypeChange(entry.game);
      document.getElementById('genRefId').value = val;

      // Switch to Code Generator tab
      const navEl = document.querySelector('a[href="#section-gen"]');
      showTab('gen', navEl);

      // Clear ref dial input & hide status
      document.getElementById('refDialInput').value = '';
      statusBox.classList.add('hidden');

      showToast('Ref set — fill name and generate!');
    }

    function switchRefTab(type) {
      document.getElementById('refListWheel').classList.toggle('hidden', type !== 'wheel');
      document.getElementById('refListMystery').classList.toggle('hidden', type !== 'mystery');
      document.getElementById('refTabWheel').classList.toggle('active', type === 'wheel');
      document.getElementById('refTabMystery').classList.toggle('active', type === 'mystery');
    }

    function highlightRef(num) {
      document.getElementById('refDialInput').value = num;
      document.getElementById('refDialInput').focus();
    }

    // ─── QR URL ───
    function updateUrl() {
      const base = document.getElementById('baseUrlInput').value.trim().replace(/\/$/, '');
      const url = base + '/feedback/general';
      document.getElementById('feedbackUrl').textContent = url;
      document.getElementById('qrGeneratorLink').href =
        `https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=${encodeURIComponent(url)}`;
      showToast('URL updated!');
    }

    function copyUrl() {
      const url = document.getElementById('feedbackUrl').textContent;
      navigator.clipboard.writeText(url).then(() => showToast('Link copied!')).catch(() => {
        prompt('Copy this link:', url);
      });
    }



    // ─── Hash-based tab on load ───
    window.addEventListener('DOMContentLoaded', () => {
      const hash = window.location.hash;
      const map = {
        '#section-gen':'gen', '#section-prizes':'prizes', '#section-games':'games',
        '#section-faculty':'faculty', '#section-players':'players',
        '#section-feedback':'feedback', '#section-qr':'qr',
        '#section-settings':'settings', '#section-revenue':'revenue',
        '#section-refdial':'refdial'
      };
      if (hash && map[hash]) {
        const navEl = document.querySelector(`a[href="${hash}"]`);
        showTab(map[hash], navEl);
      }
      <% if (generatedCode) { %>
      showTab('gen', document.querySelector('.nav-item'));
      <% } %>
    });
  </script>
</body>
</html>
