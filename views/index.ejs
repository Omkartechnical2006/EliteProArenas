<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Elite Pro Arenas | College Fest</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;600&display=swap" rel="stylesheet"/>
  <style>
    body { font-family: 'Inter', sans-serif; background: #0a0a0f; }
    .orbitron { font-family: 'Orbitron', monospace; }
    .gold-glow { text-shadow: 0 0 20px #ffd700, 0 0 40px #ffd700, 0 0 80px #ffaa00; }
    .neon-border { box-shadow: 0 0 15px rgba(255,215,0,0.4), inset 0 0 15px rgba(255,215,0,0.05); }
    .bg-grid {
      background-image: linear-gradient(rgba(255,215,0,0.05) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(255,215,0,0.05) 1px, transparent 1px);
      background-size: 50px 50px;
    }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
    @keyframes pulse-ring {
      0%{box-shadow:0 0 0 0 rgba(255,215,0,0.5)}
      70%{box-shadow:0 0 0 20px rgba(255,215,0,0)}
      100%{box-shadow:0 0 0 0 rgba(255,215,0,0)}
    }
    @keyframes shimmer {
      0%{background-position:-200% center}
      100%{background-position:200% center}
    }
    .trophy { animation: float 3s ease-in-out infinite; }
    .pulse-btn { animation: pulse-ring 2s ease-out infinite; }
    .shimmer-text {
      background: linear-gradient(90deg, #ffd700, #fff8dc, #ffd700, #ffaa00, #ffd700);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: shimmer 3s linear infinite;
    }
    .star-field { position:fixed; top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0; }
    .star { position:absolute; border-radius:50%; background:#fff; animation: twinkle var(--d,2s) ease-in-out infinite; }
    @keyframes twinkle { 0%,100%{opacity:0.2} 50%{opacity:1} }
    input:focus { outline:none; }
  </style>
</head>
<body class="min-h-screen bg-grid flex flex-col items-center justify-center relative overflow-hidden">

  <!-- Star Field -->
  <canvas id="starCanvas" class="star-field"></canvas>

  <!-- Particles -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
    <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-yellow-500 rounded-full opacity-5 blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-500 rounded-full opacity-5 blur-3xl"></div>
    <div class="absolute top-3/4 left-1/2 w-48 h-48 bg-cyan-500 rounded-full opacity-5 blur-3xl"></div>
  </div>

  <!-- Main Content -->
  <div class="relative z-10 flex flex-col items-center px-4 w-full max-w-md">

    <!-- Trophy Icon -->
    <div class="trophy text-7xl mb-4">🏆</div>

    <!-- Title -->
    <h1 class="orbitron text-4xl md:text-5xl font-black text-center mb-2 shimmer-text">
      ELITE PRO<br/>ARENAS
    </h1>
    <p class="text-yellow-400/60 text-sm tracking-[0.3em] uppercase mb-10 text-center">College Fest × Spin & Win</p>

    <!-- Card -->
    <div class="w-full bg-black/60 backdrop-blur-xl border border-yellow-500/30 rounded-2xl p-8 neon-border">

      <h2 class="orbitron text-lg text-yellow-400 text-center mb-6 tracking-wider">ENTER YOUR CODE</h2>

      <% if (error) { %>
        <div class="bg-red-900/40 border border-red-500/50 text-red-300 text-sm px-4 py-3 rounded-xl mb-5 flex items-center gap-2">
          <span><%= error %></span>
        </div>
      <% } %>

      <form action="/" method="POST" id="codeForm">
        <div class="relative mb-5">
          <input
            type="text"
            name="code"
            id="codeInput"
            maxlength="4"
            placeholder="e.g. 4821"
            autocomplete="off"
            required
            class="w-full bg-black/50 border border-yellow-500/40 text-yellow-100 text-center text-3xl font-bold tracking-[0.5em] orbitron py-5 px-4 rounded-xl placeholder-yellow-900/50 focus:border-yellow-400 focus:shadow-[0_0_20px_rgba(255,215,0,0.3)] transition-all duration-300"
            oninput="this.value=this.value.replace(/[^0-9]/g,'')"
          />
        </div>

        <button
          type="submit"
          id="spinBtn"
          class="pulse-btn w-full py-4 rounded-xl orbitron font-bold text-black text-lg tracking-wider transition-all duration-300
          bg-gradient-to-r from-yellow-400 via-yellow-300 to-yellow-500 hover:from-yellow-300 hover:to-yellow-400
          hover:shadow-[0_0_30px_rgba(255,215,0,0.6)] active:scale-95"
        >
          🎰 SPIN THE WHEEL
        </button>
      </form>

      <div class="mt-6 flex items-center justify-center gap-3">
        <div class="h-px flex-1 bg-yellow-500/20"></div>
        <span class="text-yellow-500/40 text-xs tracking-widest uppercase">Get your code at the counter</span>
        <div class="h-px flex-1 bg-yellow-500/20"></div>
      </div>
    </div>

    <!-- Bottom Badge -->
    <div class="mt-6 flex items-center gap-2 text-yellow-500/40 text-xs">
      <span>⚡</span>
      <span class="tracking-wider">POWERED BY ELITE PRO ARENAS</span>
      <span>⚡</span>
    </div>
  </div>

  <script>
    // Star canvas
    const canvas = document.getElementById('starCanvas');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    const stars = Array.from({length:120}, () => ({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      r: Math.random() * 1.5 + 0.3,
      alpha: Math.random(),
      speed: Math.random() * 0.005 + 0.002
    }));
    function drawStars() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      stars.forEach(s => {
        s.alpha += s.speed;
        if (s.alpha > 1 || s.alpha < 0) s.speed *= -1;
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,215,0,${s.alpha * 0.6})`;
        ctx.fill();
      });
      requestAnimationFrame(drawStars);
    }
    drawStars();
    window.addEventListener('resize', () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    });

    // Auto-focus
    document.getElementById('codeInput').focus();

    // Submit animation
    document.getElementById('codeForm').addEventListener('submit', function(e) {
      const btn = document.getElementById('spinBtn');
      btn.innerHTML = '⏳ Verifying...';
      btn.disabled = true;
    });
  </script>
</body>
</html>
