<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>404 | Elite Pro Arenas</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@400;600&display=swap" rel="stylesheet"/>
  <style>
    body { font-family:'Inter',sans-serif; background:#0a0a0f; }
    .orbitron { font-family:'Orbitron',monospace; }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-15px)} }
    .float { animation: float 3s ease-in-out infinite; }
    @keyframes glitch {
      0%,100%{text-shadow:2px 0 #ffd700,-2px 0 #ff00ff}
      25%{text-shadow:-2px 0 #ffd700,2px 0 #00ffff}
      50%{text-shadow:2px 2px #ffaa00,-2px -2px #ff0000}
    }
    .glitch { animation: glitch 1.5s ease-in-out infinite; }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center text-center px-4">
  <div>
    <div class="float text-8xl mb-6">🚀</div>
    <h1 class="orbitron text-9xl font-black text-yellow-400 glitch mb-4">404</h1>
    <p class="orbitron text-xl text-gray-400 mb-2 tracking-wider">ARENA NOT FOUND</p>
    <p class="text-gray-600 text-sm mb-8">The page you're looking for doesn't exist in our universe.</p>
    <a href="/" class="orbitron bg-gradient-to-r from-yellow-400 to-yellow-500 text-black font-bold px-8 py-3 rounded-full hover:shadow-[0_0_25px_rgba(255,215,0,0.5)] transition-all text-sm tracking-wider">
      🏠 BACK TO HOME
    </a>
  </div>
</body>
</html>
