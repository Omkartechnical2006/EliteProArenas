<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Mystery Box | Elite Pro Arenas</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family:'Inter',sans-serif; background:#0a0208; color:#e8e0f0; min-height:100vh; overflow-x:hidden; }
    .orbitron { font-family:'Orbitron',monospace; }
    .bg-grid {
      background-image: linear-gradient(rgba(168,85,247,0.04) 1px,transparent 1px),
                        linear-gradient(90deg,rgba(168,85,247,0.04) 1px,transparent 1px);
      background-size: 50px 50px;
    }

    /* ── PARTICLES ── */
    .particle { position:fixed; pointer-events:none; z-index:1; border-radius:50%; animation:floatUp 10s linear infinite; opacity:0; }
    @keyframes floatUp { 0%{transform:translateY(0) rotate(0);opacity:0} 10%{opacity:0.7} 90%{opacity:0.3} 100%{transform:translateY(-100vh) rotate(360deg);opacity:0} }

    /* ── HEADER ── */
    .game-header { text-align:center; padding:28px 20px 20px; position:relative; z-index:10; }
    .game-header h1 { font-family:'Orbitron',monospace; font-size:clamp(1.4rem,4vw,2.2rem); font-weight:900; color:#c084fc; text-shadow:0 0 20px rgba(192,132,252,0.5); margin-bottom:6px; }
    .game-header p { color:rgba(255,255,255,0.5); font-size:0.9rem; }
    .player-name { color:#f0abfc; font-weight:700; }

    /* ── BOX GRID ── */
    .arena { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:10px 20px 30px; min-height:calc(100vh - 120px); position:relative; z-index:10; }
    .instruction { font-size:0.85rem; color:rgba(192,132,252,0.7); letter-spacing:0.15em; text-transform:uppercase; margin-bottom:24px; text-align:center; }
    .box-grid { display:grid; grid-template-columns:repeat(3, 1fr); gap:20px; max-width:540px; width:100%; }
    @media(max-width:480px){ .box-grid{ gap:12px; max-width:340px; } }

    /* ── MYSTERY BOX ── */
    .mystery-box {
      aspect-ratio:1; position:relative;
      cursor:pointer; border-radius:20px;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .mystery-box:hover:not(.disabled):not(.opened) { transform:translateY(-6px) scale(1.04); }
    .mystery-box.disabled { cursor:not-allowed; }

    .box-inner {
      width:100%; height:100%; border-radius:20px;
      position:relative; overflow:hidden;
      background: linear-gradient(135deg,#1a0535,#0d0220,#1a0535);
      border:2px solid rgba(192,132,252,0.4);
      box-shadow: 0 8px 32px rgba(168,85,247,0.2), inset 0 0 30px rgba(168,85,247,0.05);
      transition: all 0.3s;
      display:flex; align-items:center; justify-content:center; flex-direction:column;
    }
    .mystery-box:hover:not(.disabled):not(.opened) .box-inner {
      border-color:rgba(240,171,252,0.8);
      box-shadow: 0 12px 40px rgba(168,85,247,0.5), inset 0 0 30px rgba(168,85,247,0.1), 0 0 20px rgba(240,171,252,0.3);
    }

    /* Ribbon on box */
    .box-ribbon-h {
      position:absolute; top:50%; left:0; right:0; height:4px;
      background:linear-gradient(90deg,transparent,rgba(240,171,252,0.5),transparent);
      transform:translateY(-50%);
    }
    .box-ribbon-v {
      position:absolute; left:50%; top:0; bottom:0; width:4px;
      background:linear-gradient(180deg,transparent,rgba(240,171,252,0.5),transparent);
      transform:translateX(-50%);
    }

    .box-qmark { font-size:clamp(1.8rem,5vw,2.8rem); filter:drop-shadow(0 0 8px rgba(192,132,252,0.8)); transition:all 0.3s; }
    .mystery-box:not(.opened):not(.disabled):hover .box-qmark { animation:qmarkWiggle 0.5s ease; }
    @keyframes qmarkWiggle { 0%,100%{transform:scale(1) rotate(0)} 25%{transform:scale(1.2) rotate(-10deg)} 75%{transform:scale(1.2) rotate(10deg)} }

    /* ── BOX OPEN STATE ── */
    .mystery-box.opening { animation:boxShake 0.5s ease; }
    @keyframes boxShake {
      0%,100%{transform:translateX(0) scale(1)}
      15%{transform:translateX(-8px) scale(1.05)}
      30%{transform:translateX(8px) scale(1.08)}
      45%{transform:translateX(-6px) scale(1.06)}
      60%{transform:translateX(6px) scale(1.04)}
      75%{transform:translateX(-3px) scale(1.02)}
    }
    .mystery-box.opened .box-inner {
      border-color: rgba(255,215,0,0.8);
      box-shadow: 0 0 40px rgba(255,215,0,0.5), 0 0 80px rgba(255,215,0,0.2), inset 0 0 30px rgba(255,215,0,0.1);
      background: linear-gradient(135deg,#1a1400,#2a2000,#1a1400);
    }
    .mystery-box.opened.is-player-box .box-inner {
      box-shadow: 0 0 60px rgba(255,215,0,0.8), 0 0 120px rgba(255,215,0,0.4), inset 0 0 40px rgba(255,215,0,0.15);
      animation: winPulse 1.5s ease-in-out infinite;
    }
    @keyframes winPulse { 0%,100%{box-shadow:0 0 60px rgba(255,215,0,0.8)} 50%{box-shadow:0 0 100px rgba(255,215,0,1)} }

    .prize-content { display:none; flex-direction:column; align-items:center; justify-content:center; padding:8px; text-align:center; }
    .mystery-box.opened .prize-content { display:flex; animation:prizeReveal 0.6s cubic-bezier(0.175,0.885,0.32,1.275) 0.4s both; }
    .mystery-box.opened .box-qmark, .mystery-box.opened .box-ribbon-h, .mystery-box.opened .box-ribbon-v { display:none; }
    @keyframes prizeReveal { from{transform:scale(0) rotate(-10deg);opacity:0} to{transform:scale(1) rotate(0);opacity:1} }

    .prize-emoji { font-size:clamp(1.4rem,4vw,2rem); margin-bottom:4px; }
    .prize-label { font-size:clamp(0.5rem,1.5vw,0.7rem); color:rgba(255,255,255,0.8); text-align:center; font-weight:600; line-height:1.2; }
    .your-prize-tag {
      position:absolute; top:-10px; left:50%; transform:translateX(-50%);
      background:linear-gradient(135deg,#ffd700,#ffaa00); color:#000;
      font-size:0.55rem; font-weight:900; padding:3px 10px; border-radius:20px;
      font-family:'Orbitron',monospace; letter-spacing:0.05em; white-space:nowrap;
      box-shadow:0 0 12px rgba(255,215,0,0.6);
    }

    /* ── SPARKLES ── */
    .sparkle { position:absolute; pointer-events:none; animation:sparkleFly 0.8s ease-out forwards; font-size:1.2rem; }
    @keyframes sparkleFly { 0%{transform:translate(0,0) scale(1);opacity:1} 100%{transform:translate(var(--tx),var(--ty)) scale(0);opacity:0} }

    /* ── MODAL ── */
    #resultModal {
      display:none; position:fixed; inset:0;
      background:rgba(0,0,0,0.9); backdrop-filter:blur(12px);
      z-index:100; align-items:center; justify-content:center;
    }
    #resultModal.show { display:flex; }
    .modal-card {
      background:linear-gradient(135deg,#16002e,#0d0020,#1a003a);
      border:2px solid rgba(240,171,252,0.5);
      border-radius:28px; padding:44px 36px; text-align:center;
      max-width:400px; width:92%;
      box-shadow:0 0 60px rgba(168,85,247,0.4), 0 0 120px rgba(168,85,247,0.1);
      animation:popIn 0.6s cubic-bezier(0.175,0.885,0.32,1.275);
    }
    @keyframes popIn { from{transform:scale(0.5) rotate(-5deg);opacity:0} to{transform:scale(1) rotate(0);opacity:1} }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
    /* ── GIFT BOX ANIMATION ── */
    .gift-wrap {
      position:relative; width:90px; height:90px;
      margin:0 auto 16px; flex-shrink:0;
    }
    .g-body {
      position:absolute; bottom:0; left:4px; right:4px; height:56px;
      background:linear-gradient(135deg,#a855f7,#7c3aed);
      border-radius:6px 6px 10px 10px;
      border:2px solid rgba(240,171,252,0.5);
      box-shadow:0 0 20px rgba(168,85,247,0.6);
    }
    .g-body::after {
      content:''; position:absolute; top:0; bottom:0;
      left:50%; transform:translateX(-50%);
      width:12px; background:rgba(240,171,252,0.35);
    }
    .g-lid {
      position:absolute; top:22px; left:0; right:0; height:24px;
      background:linear-gradient(135deg,#c084fc,#9333ea);
      border-radius:6px;
      border:2px solid rgba(240,171,252,0.6);
      transform-origin:0% 100%;
      z-index:3;
    }
    .g-lid::after {
      content:''; position:absolute; top:50%; left:0; right:0;
      transform:translateY(-50%);
      height:10px; background:rgba(240,171,252,0.35);
    }
    .g-bow-l, .g-bow-r {
      position:absolute; top:14px; width:18px; height:16px;
      background:#f0abfc; border-radius:50% 50% 50% 0;
      z-index:4;
    }
    .g-bow-l { left:20px; transform:rotate(-40deg); }
    .g-bow-r { right:20px; transform:rotate(40deg) scaleX(-1); }
    .g-prize-out {
      position:absolute; top:16px; left:50%; transform:translateX(-50%);
      font-size:2.4rem; z-index:5; opacity:0;
    }
    /* lid opens upward, prize pops out */
    .gift-wrap.open .g-lid      { animation:lidOpen 0.5s ease-out 0.5s forwards; }
    .gift-wrap.open .g-bow-l    { animation:lidOpen 0.5s ease-out 0.5s forwards; }
    .gift-wrap.open .g-bow-r    { animation:lidOpen 0.5s ease-out 0.5s forwards; }
    .gift-wrap.open .g-prize-out{ animation:prizePopUp 0.7s cubic-bezier(0.175,0.885,0.32,1.275) 0.9s forwards; }
    @keyframes lidOpen    { 0%{transform:rotate(0) translate(0,0)} 100%{transform:rotate(-55deg) translate(-28%,-70%)} }
    @keyframes prizePopUp { 0%{opacity:0;top:50px} 60%{opacity:1;top:-22px} 100%{opacity:1;top:-18px} }
    .modal-title { font-family:'Orbitron',monospace; color:#f0abfc; font-size:1.5rem; font-weight:900; margin-bottom:8px; }
    .modal-prize-box {
      background:rgba(255,215,0,0.08); border:2px solid rgba(255,215,0,0.4);
      border-radius:16px; padding:16px 24px; margin:16px 0 24px;
    }
    .modal-prize-label { font-size:0.7rem; color:rgba(255,215,0,0.6); text-transform:uppercase; letter-spacing:0.2em; margin-bottom:6px; }
    .modal-prize-name { font-family:'Orbitron',monospace; font-size:1.1rem; font-weight:900; color:#ffd700; text-shadow:0 0 16px rgba(255,215,0,0.6); word-break:break-word; }

    .btn-reveal {
      width:100%; padding:14px; margin-bottom:12px;
      background:linear-gradient(135deg,#a855f7,#7c3aed);
      color:#fff; font-family:'Orbitron',monospace; font-weight:900;
      font-size:0.85rem; letter-spacing:0.1em; border:none; border-radius:14px;
      cursor:pointer; transition:all 0.3s;
      box-shadow:0 4px 20px rgba(168,85,247,0.4);
    }
    .btn-reveal:hover { transform:translateY(-2px); box-shadow:0 8px 30px rgba(168,85,247,0.6); }
    .btn-feedback {
      width:100%; padding:14px;
      background:linear-gradient(135deg,#ffd700,#ffaa00);
      color:#000; font-family:'Orbitron',monospace; font-weight:900;
      font-size:0.85rem; letter-spacing:0.1em; border:none; border-radius:14px;
      cursor:pointer; transition:all 0.3s;
      box-shadow:0 4px 20px rgba(255,215,0,0.3);
    }
    .btn-feedback:hover { transform:translateY(-2px); box-shadow:0 8px 30px rgba(255,215,0,0.5); }
    .btn-feedback:disabled { opacity:0.5; cursor:not-allowed; transform:none; }

    /* ── COLLECT BANNER ── */
    #collectBanner {
      display:none; position:fixed; bottom:0; left:0; right:0; z-index:50;
      background: rgba(30, 0, 60, 0.55);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-top: 1px solid rgba(168,85,247,0.25);
      padding:8px 20px; text-align:center;
    }
    #collectBanner.show { display:block; }
    @keyframes bgSlide { 0%{background-position:0% center} 100%{background-position:200% center} }
    .collect-text { font-family:'Orbitron',monospace; font-size:0.7rem; color:rgba(240,171,252,0.75); font-weight:500; letter-spacing:0.08em; }

    /* ── FLOATING FEEDBACK CARD ── */
    #feedbackFloat {
      display:none;
      position:fixed; bottom:50px; left:50%; transform:translateX(-50%);
      z-index:60; width:min(92vw,360px);
    }
    #feedbackFloat.show { display:block; animation:popIn 0.7s cubic-bezier(0.175,0.885,0.32,1.275); }
    .feedback-glass-card {
      background: rgba(20,0,40,0.65);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(240,171,252,0.3);
      border-radius: 22px;
      padding: 18px 24px;
      text-align:center;
      box-shadow: 0 8px 32px rgba(168,85,247,0.3), 0 0 0 1px rgba(240,171,252,0.08) inset;
    }
    .feedback-glass-card p {
      font-size:0.72rem; color:rgba(240,171,252,0.7);
      margin-bottom:12px; letter-spacing:0.05em;
    }
    .btn-feedback-float {
      width:100%; padding:13px 32px;
      background:linear-gradient(135deg,#ffd700,#ffaa00,#ffd700);
      background-size:200% auto;
      color:#000; font-family:'Orbitron',monospace; font-weight:800;
      font-size:0.8rem; letter-spacing:0.12em; border:none; border-radius:14px;
      cursor:pointer; transition:all 0.3s; white-space:nowrap;
      box-shadow:0 0 20px rgba(255,215,0,0.4), 0 4px 14px rgba(0,0,0,0.5);
      animation:shimmer 2s linear infinite;
    }
    @keyframes shimmer { 0%{background-position:0% center} 100%{background-position:200% center} }
    .btn-feedback-float:hover { transform:translateY(-2px); box-shadow:0 0 32px rgba(255,215,0,0.6); }
  </style>
</head>
<body class="bg-grid">

  <!-- Ambient glow -->
  <div style="position:fixed;top:0;right:0;width:400px;height:400px;background:radial-gradient(circle,rgba(168,85,247,0.08) 0%,transparent 70%);pointer-events:none;z-index:1;"></div>
  <div style="position:fixed;bottom:0;left:0;width:400px;height:400px;background:radial-gradient(circle,rgba(6,182,212,0.06) 0%,transparent 70%);pointer-events:none;z-index:1;"></div>
  <div id="particles"></div>

  <!-- Header -->
  <div class="game-header">
    <h1>🎁 MYSTERY BOX</h1>
    <p>Good luck, <span class="player-name"><%= player.name %></span>! ✨ Pick your lucky box!</p>
  </div>

  <!-- Arena -->
  <div class="arena">
    <div class="instruction">✨ Choose any one mystery box to reveal your prize ✨</div>
    <div class="box-grid" id="boxGrid">
      <!-- boxes generated by JS -->
    </div>
  </div>

  <!-- Result Modal -->
  <div id="resultModal">
    <div class="modal-card">
      <!-- Animated Gift Box -->
      <div class="gift-wrap" id="giftWrap">
        <div class="g-bow-l"></div>
        <div class="g-bow-r"></div>
        <div class="g-lid"></div>
        <div class="g-body"></div>
        <div class="g-prize-out" id="gPrizeOut">🎁</div>
      </div>
      <div class="modal-title" id="modalTitle">CONGRATULATIONS!</div>
      <p id="modalSubtitle" style="color:rgba(255,255,255,0.5);font-size:0.82rem;margin-bottom:4px;">You found the right box, <span style="color:#f0abfc;font-weight:700;"><%= player.name %></span>!</p>
      <div class="modal-prize-box">
        <div class="modal-prize-label" id="modalPrizeLabel">🏆 Your Prize</div>
        <div class="modal-prize-name" id="modalPrizeName"></div>
      </div>
      <p id="modalClaimText" style="color:rgba(255,255,255,0.35);font-size:0.75rem;margin-bottom:20px;">Show this to the stall coordinator to claim your prize!</p>
      <button class="btn-reveal" id="revealAllBtn" onclick="revealAllBoxes()">🎁 Reveal All Boxes</button>
      <button class="btn-feedback" id="feedbackBtn" onclick="goFeedback()" disabled>📝 Give Feedback</button>
    </div>
  </div>

  <!-- Collect Banner -->
  <div id="collectBanner">
    <div class="collect-text">🏆 CLAIM YOUR PRIZE AT THE STALL COUNTER &nbsp;&bull;&nbsp; <%= player.assignedPrize %> &nbsp;&bull;&nbsp; CODE: <%= player.uniqueCode %></div>
  </div>

  <!-- Floating Feedback Button (shown after Reveal All) -->
  <div id="feedbackFloat">
    <div class="feedback-glass-card">
      <p>🎊 All boxes revealed! Ready to share your experience?</p>
      <button class="btn-feedback-float" onclick="goFeedback()">📝 GIVE FEEDBACK</button>
    </div>
  </div>



  <script>
    const ASSIGNED_PRIZE = "<%= assignedPrize %>";
    const ALL_PRIZES     = <%- allPrizes %>;
    const BOX_COUNT      = <%= boxCount %>;
    const UNIQUE_CODE    = "<%= player.uniqueCode %>";
    const FEEDBACK_URL   = "/feedback/" + UNIQUE_CODE;

    let playerBoxIndex = Math.floor(Math.random() * BOX_COUNT);
    let boxOpened = false;
    let revealingAll = false;
    let revealDone = false;
    const boxStates = Array(BOX_COUNT).fill(null).map((_,i) => ({ opened:false, isPlayer: i === playerBoxIndex }));

    // ── Build a STRICTLY UNIQUE prize pool (no duplicates whatsoever) ──
    // Each box gets its own unique prize; the clicked box is overwritten with ASSIGNED_PRIZE.
    function buildUniquePrizePool(allPrizes, exclude, count) {
      // Deduplicate and remove the assigned prize
      const pool = [...new Set(allPrizes.filter(p => p !== exclude))];
      // Fisher-Yates shuffle
      for (let i = pool.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [pool[i], pool[j]] = [pool[j], pool[i]];
      }
      // If pool is still not big enough, supplement with remaining prizes (including exclude)
      if (pool.length < count) {
        const extra = [...new Set(allPrizes)].filter(p => !pool.includes(p));
        pool.push(...extra);
      }
      return pool.slice(0, count);
    }
    const otherPrizes = buildUniquePrizePool(ALL_PRIZES, ASSIGNED_PRIZE, BOX_COUNT);
    const prizeAssignments = [...otherPrizes];
    // Note: when user clicks a box, prizeAssignments[idx] is overwritten with ASSIGNED_PRIZE

    // ── Render boxes ──
    const grid = document.getElementById('boxGrid');
    for (let i = 0; i < BOX_COUNT; i++) {
      const box = document.createElement('div');
      box.className = 'mystery-box';
      box.id = `box-${i}`;
      box.dataset.idx = i;
      box.onclick = () => clickBox(i);
      box.innerHTML = `
        <div class="box-inner">
          <div class="box-ribbon-h"></div>
          <div class="box-ribbon-v"></div>
          <div class="box-qmark">❓</div>
          <div class="prize-content" id="prize-content-${i}">
            <div class="prize-emoji" id="prize-emoji-${i}">🎁</div>
            <div class="prize-label" id="prize-label-${i}"></div>
          </div>
        </div>`;
      grid.appendChild(box);
    }

    // ── Click box handler ──
    function clickBox(idx) {
      if (boxOpened || revealingAll) return;
      boxOpened = true;

      // The player always wins their assigned prize regardless of which box they pick
      playerBoxIndex = idx;
      boxStates[idx].isPlayer = true;
      // Override prize assignment for clicked box
      prizeAssignments[idx] = ASSIGNED_PRIZE;

      const box = document.getElementById(`box-${idx}`);
      box.classList.add('opening');
      setTimeout(() => {
        openBox(idx, ASSIGNED_PRIZE, true);
        markSpunOnServer();
        setTimeout(() => showModal(), 700);
      }, 500);

      // Disable all other boxes
      for (let i = 0; i < BOX_COUNT; i++) {
        if (i !== idx) document.getElementById(`box-${i}`).classList.add('disabled');
      }
    }

    // ── Open a single box ──
    function openBox(idx, prize, isPlayer) {
      const box = document.getElementById(`box-${idx}`);
      box.classList.remove('opening');
      box.classList.add('opened');
      if (isPlayer) box.classList.add('is-player-box');
      boxStates[idx].opened = true;

      // Set prize content
      const labelEl = document.getElementById(`prize-label-${idx}`);
      const emojiEl = document.getElementById(`prize-emoji-${idx}`);

      // Extract emoji if present at end of prize string
      const parts = prize.split(' ');
      const lastPart = parts[parts.length - 1];
      const isEmoji = /\p{Emoji}/u.test(lastPart);
      if (isEmoji && parts.length > 1) {
        emojiEl.textContent = lastPart;
        labelEl.textContent = parts.slice(0, -1).join(' ');
      } else {
        emojiEl.textContent = '🎁';
        labelEl.textContent = prize;
      }

      if (isPlayer) {
        // Add "YOUR PRIZE" tag
        const tag = document.createElement('div');
        tag.className = 'your-prize-tag';
        tag.textContent = '⭐ YOUR PRIZE';
        box.appendChild(tag);
        spawnSparkles(box);
      }
    }

    // ── Sparkles ──
    function spawnSparkles(box) {
      const rect  = box.getBoundingClientRect();
      const emojis = ['✨','⭐','🌟','💫','🎊'];
      for (let i = 0; i < 8; i++) {
        const s = document.createElement('div');
        s.className = 'sparkle';
        const angle = (i / 8) * Math.PI * 2;
        const dist  = 50 + Math.random() * 40;
        s.style.cssText = `left:${rect.left+rect.width/2}px;top:${rect.top+rect.height/2}px;position:fixed;z-index:200;--tx:${Math.cos(angle)*dist}px;--ty:${Math.sin(angle)*dist}px;animation-delay:${i*0.05}s;`;
        s.textContent = emojis[i % emojis.length];
        document.body.appendChild(s);
        setTimeout(() => s.remove(), 1000);
      }
    }

    // ── Helper: play a sound via new Audio() (more reliable than HTML elements) ──
    function playSound(url, volume) {
      try {
        const a = new Audio(url);
        a.volume = volume || 0.65;
        a.play().catch(() => {});
      } catch(e) {}
    }
    const WIN_SOUND     = '/sounds/win.mp3';
    const LOSS_SOUND    = '/sounds/lose.mp3';
    const SCRATCH_SOUND = '/sounds/scratch.mp3';

    // ── Show modal (win OR loss depending on assigned prize) ──
    function showModal() {
      const isLoss = /better luck|next time/i.test(ASSIGNED_PRIZE);

      // Extract the emoji from the prize string for the gift box pop-out
      const emojiMatch = ASSIGNED_PRIZE.match(/\p{Emoji_Presentation}|\p{Extended_Pictographic}/gu);
      const prizeEmoji = emojiMatch ? emojiMatch[emojiMatch.length - 1] : (isLoss ? '😅' : '🎁');
      document.getElementById('gPrizeOut').textContent = prizeEmoji;

      document.getElementById('modalPrizeName').textContent = ASSIGNED_PRIZE;
      document.getElementById('resultModal').classList.add('show');

      // Trigger gift box open animation after a short delay
      setTimeout(() => document.getElementById('giftWrap').classList.add('open'), 200);

      if (isLoss) {
        document.getElementById('modalTitle').textContent = 'BETTER LUCK NEXT TIME!';
        document.getElementById('modalTitle').style.color = '#f87171';
        document.getElementById('modalSubtitle').innerHTML = 'Don\'t worry, <span style="color:#f0abfc;font-weight:700;"><%= player.name %></span>! Better luck next time!';
        document.getElementById('modalPrizeLabel').textContent = '💔 Result';
        document.getElementById('modalClaimText').style.display = 'none';
        // Grey out gift box body for loss
        document.querySelector('.g-body').style.background = 'linear-gradient(135deg,#4b5563,#374151)';
        document.querySelector('.g-lid').style.background  = 'linear-gradient(135deg,#6b7280,#4b5563)';
        playSound(LOSS_SOUND, 0.6);
      } else {
        document.getElementById('modalTitle').textContent = 'CONGRATULATIONS!';
        document.getElementById('modalTitle').style.color = '#f0abfc';
        document.getElementById('modalSubtitle').innerHTML = 'You found the right box, <span style="color:#f0abfc;font-weight:700;"><%= player.name %></span>!';
        document.getElementById('modalPrizeLabel').textContent = '🏆 Your Prize';
        document.getElementById('modalClaimText').style.display = '';
        // Confetti after lid opens
        setTimeout(() => {
          confetti({ particleCount:200, spread:80, origin:{y:0.6}, colors:['#a855f7','#c084fc','#ffd700','#f0abfc','#ffffff'] });
          setTimeout(() => confetti({ particleCount:150, spread:120, origin:{y:0.6}, colors:['#ffd700','#ff6b6b','#f0abfc'] }), 500);
        }, 1000);
        playSound(WIN_SOUND, 0.7);
      }
    }

    // ── Reveal all boxes ──
    function revealAllBoxes() {
      revealingAll = true;

      // 1. Close the modal so user can see the boxes
      document.getElementById('resultModal').classList.remove('show');

      // 2. Update instruction text
      document.querySelector('.instruction').innerHTML =
        '✨ Look what was hidden in all the other boxes! ✨';

      let delay = 0;
      for (let i = 0; i < BOX_COUNT; i++) {
        if (!boxStates[i].opened) {
          delay += 420;
          // Use the pre-assigned prize for each box
          const prize = prizeAssignments[i];
          const ii    = i;
          const dd    = delay;
          setTimeout(() => {
            const box = document.getElementById(`box-${ii}`);
            box.classList.remove('disabled');
            box.classList.add('opening');
            // Play scratch sound for each box reveal
            playSound(SCRATCH_SOUND, 0.6);
            setTimeout(() => {
              openBox(ii, prize, false);
              // Little sparkle on each box open
              spawnSparkles(box);
            }, 300);
          }, dd);
        }
      }

      // 3. After all revealed — show collect banner + floating feedback button
      setTimeout(() => {
        revealDone = true;
        document.getElementById('collectBanner').classList.add('show');
        document.getElementById('feedbackFloat').classList.add('show');

        // Final big confetti burst
        confetti({ particleCount:300, spread:100, origin:{y:0.5}, colors:['#a855f7','#ffd700','#ffffff','#f0abfc'] });
        setTimeout(() => confetti({ particleCount:200, spread:120, origin:{y:0.3}, colors:['#ffd700','#ff6b6b','#f0abfc'] }), 600);
      }, delay + 500);
    }

    // ── Navigation ──
    function goFeedback() {
      window.location.href = FEEDBACK_URL;
    }

    // ── Mark spun on server ──
    function markSpunOnServer() {
      fetch('/game/mark-spun', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ uniqueCode: UNIQUE_CODE })
      });
    }

    // ── Floating particles background ──
    const pContainer = document.getElementById('particles');
    const pColors = ['#a855f7','#7c3aed','#c084fc','#f0abfc','#ffd700'];
    for (let i = 0; i < 20; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      const size = Math.random() * 5 + 2;
      p.style.cssText = `width:${size}px;height:${size}px;left:${Math.random()*100}%;bottom:0;background:${pColors[i%pColors.length]};animation-duration:${8+Math.random()*10}s;animation-delay:-${Math.random()*15}s;`;
      pContainer.appendChild(p);
    }
  </script>
</body>
</html>
