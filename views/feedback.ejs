<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Feedback | Elite Pro Arenas</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js"></script>
  <style>
    body { font-family:'Inter',sans-serif; background:#0a0a0f; }
    .orbitron { font-family:'Orbitron',monospace; }
    .bg-grid {
      background-image:linear-gradient(rgba(255,215,0,0.03) 1px,transparent 1px),
                       linear-gradient(90deg,rgba(255,215,0,0.03) 1px,transparent 1px);
      background-size:50px 50px;
    }
    .star-row { display:flex; gap:8px; cursor:pointer; }
    .star-icon {
      font-size:2rem; transition:transform 0.15s, filter 0.15s;
      filter:grayscale(1) brightness(0.5);
    }
    .star-icon.active { filter:none; transform:scale(1.15); }
    .star-icon:hover { transform:scale(1.2); }
    .neon-card {
      background:rgba(0,0,0,0.6);
      border:1px solid rgba(255,215,0,0.25);
      backdrop-filter:blur(16px);
      box-shadow:0 0 30px rgba(255,215,0,0.08), inset 0 0 30px rgba(255,215,0,0.02);
    }
    .success-modal {
      display:none; position:fixed; inset:0;
      background:rgba(0,0,0,0.9); backdrop-filter:blur(12px);
      z-index:100; align-items:center; justify-content:center;
    }
    .success-modal.show { display:flex; }
    .success-card {
      background:linear-gradient(135deg,#1a1a2e,#16213e);
      border:2px solid #ffd700; border-radius:24px;
      padding:48px 36px; text-align:center;
      max-width:380px; width:90%;
      box-shadow:0 0 60px rgba(255,215,0,0.4);
      animation:popIn 0.6s cubic-bezier(0.175,0.885,0.32,1.275);
    }
    @keyframes popIn {
      from{transform:scale(0.4) rotate(-10deg);opacity:0}
      to{transform:scale(1) rotate(0deg);opacity:1}
    }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
    .float-anim { animation:float 2s ease-in-out infinite; }
    textarea:focus, input:focus { outline:none; }
    .submit-btn {
      background:linear-gradient(135deg,#ffd700,#ffaa00);
      transition:all 0.3s;
    }
    .submit-btn:hover { box-shadow:0 0 30px rgba(255,215,0,0.6); transform:translateY(-2px); }
    .submit-btn:active { transform:translateY(0); }
    .rating-section {
      border:1px solid rgba(255,215,0,0.15);
      border-radius:12px; padding:16px;
      background:rgba(255,215,0,0.03);
      transition:border-color 0.3s;
    }
    .rating-section:hover { border-color:rgba(255,215,0,0.3); }
  </style>
</head>
<body class="bg-grid min-h-screen py-8 px-4">

  <!-- Ambient -->
  <div class="fixed inset-0 pointer-events-none overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-yellow-500 rounded-full opacity-5 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-purple-600 rounded-full opacity-5 blur-3xl"></div>
  </div>

  <div class="max-w-2xl mx-auto relative z-10">

    <!-- Header -->
    <div class="text-center mb-8">
      <div class="text-5xl mb-3">📝</div>
      <h1 class="orbitron text-3xl md:text-4xl font-black text-yellow-400 tracking-wider mb-2">FEEDBACK</h1>
      <p class="text-gray-400">Hey <span class="text-yellow-300 font-bold text-lg"><%= player.name %></span>! 👋</p>
      <p class="text-gray-500 text-sm mt-1">We'd love to hear about your experience at Elite Pro Arenas</p>
    </div>

    <% if (submitted) { %>
      <!-- Already submitted or success fallback -->
      <div class="neon-card rounded-2xl p-8 text-center">
        <div class="text-6xl mb-4">✅</div>
        <h2 class="orbitron text-yellow-400 text-xl mb-2">THANK YOU!</h2>
        <p class="text-gray-300 mb-6"><%= typeof message !== 'undefined' ? message : 'Your feedback has been recorded.' %></p>
        <a href="/" class="inline-block orbitron font-bold bg-gradient-to-r from-yellow-400 to-yellow-500 text-black px-8 py-3 rounded-xl hover:shadow-[0_0_25px_rgba(255,215,0,0.5)] transition-all">
          🏠 Back to Home
        </a>
      </div>
    <% } else { %>

    <form action="/feedback/<%= player.uniqueCode %>" method="POST" id="feedbackForm">

      <!-- Overall Stall Rating -->
      <div class="neon-card rounded-2xl p-6 mb-5">
        <h2 class="orbitron text-yellow-400 text-base font-bold mb-4 tracking-wider flex items-center gap-2">
          <span>🏟️</span> OVERALL STALL RATING
        </h2>
        <div class="rating-section">
          <p class="text-gray-300 text-sm mb-3">How was your overall experience at our stall?</p>
          <div class="star-row" id="stallStars" data-target="stallRating">
            <span class="star-icon" data-val="1">⭐</span>
            <span class="star-icon" data-val="2">⭐</span>
            <span class="star-icon" data-val="3">⭐</span>
            <span class="star-icon" data-val="4">⭐</span>
            <span class="star-icon" data-val="5">⭐</span>
          </div>
          <input type="hidden" name="stallRating" id="stallRating" required/>
          <p class="text-yellow-500/60 text-xs mt-2" id="stallLabel">Click to rate</p>
        </div>
      </div>

      <!-- Game Ratings -->
      <% if (activeGames && activeGames.length > 0) { %>
      <div class="neon-card rounded-2xl p-6 mb-5">
        <h2 class="orbitron text-yellow-400 text-base font-bold mb-4 tracking-wider flex items-center gap-2">
          <span>🎮</span> GAME RATINGS
        </h2>
        <div class="space-y-4">
          <% activeGames.forEach((game, idx) => { %>
          <div class="rating-section">
            <p class="text-gray-200 font-semibold mb-2 text-sm"><%= game.gameName %></p>
            <div class="star-row" id="gameStars_<%= game._id %>" data-target="game_<%= game._id %>">
              <span class="star-icon" data-val="1">⭐</span>
              <span class="star-icon" data-val="2">⭐</span>
              <span class="star-icon" data-val="3">⭐</span>
              <span class="star-icon" data-val="4">⭐</span>
              <span class="star-icon" data-val="5">⭐</span>
            </div>
            <input type="hidden" name="game_<%= game._id %>" id="game_<%= game._id %>"/>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Comments -->
      <div class="neon-card rounded-2xl p-6 mb-6">
        <h2 class="orbitron text-yellow-400 text-base font-bold mb-4 tracking-wider flex items-center gap-2">
          <span>💬</span> YOUR COMMENTS
        </h2>
        <textarea
          name="comments"
          id="comments"
          rows="4"
          placeholder="Tell us what you loved, what could be better, or any feedback you have..."
          class="w-full bg-black/40 border border-yellow-500/20 text-gray-200 text-sm px-4 py-3 rounded-xl resize-none placeholder-gray-600 focus:border-yellow-400 focus:shadow-[0_0_15px_rgba(255,215,0,0.2)] transition-all"
        ></textarea>
      </div>

      <!-- Submit -->
      <button type="submit" id="submitBtn" class="submit-btn w-full py-4 rounded-xl orbitron font-black text-black text-lg tracking-wider">
        🚀 SUBMIT FEEDBACK
      </button>
    </form>

    <% } %>
  </div>

  <!-- Success Modal -->
  <div id="successModal" class="success-modal">
    <div class="success-card">
      <div class="text-7xl mb-4 float-anim">🎊</div>
      <h2 class="orbitron text-yellow-400 text-2xl font-black mb-2">THANK YOU!</h2>
      <p class="text-gray-300 text-sm mb-2"><span class="text-yellow-300 font-bold"><%= player.name %></span>, your feedback means the world to us!</p>
      <p class="text-gray-500 text-xs mb-8">See you at the next fest! 🏆</p>
      <button onclick="window.location.href='/'" class="w-full py-3 rounded-xl orbitron font-bold text-black bg-gradient-to-r from-yellow-400 to-yellow-500 hover:shadow-[0_0_25px_rgba(255,215,0,0.5)] transition-all text-sm tracking-wider">
        🏠 GO HOME
      </button>
    </div>
  </div>

  <!-- Success Audio -->
  <audio id="successSound">
    <source src="https://assets.mixkit.co/active_storage/sfx/1435/1435-preview.mp3" type="audio/mpeg"/>
  </audio>

  <script>
    const starLabels = ['','Poor 😞','Fair 😐','Good 😊','Great 😄','Excellent 🤩'];

    // Init all star rows
    document.querySelectorAll('.star-row').forEach(row => {
      const targetId = row.dataset.target;
      const input = document.getElementById(targetId);
      const stars = row.querySelectorAll('.star-icon');
      let selected = 0;

      const labelEl = document.getElementById(targetId === 'stallRating' ? 'stallLabel' : null);

      stars.forEach(star => {
        star.addEventListener('mouseenter', () => {
          const val = parseInt(star.dataset.val);
          stars.forEach(s => {
            s.classList.toggle('active', parseInt(s.dataset.val) <= val);
          });
        });

        star.addEventListener('mouseleave', () => {
          stars.forEach(s => {
            s.classList.toggle('active', parseInt(s.dataset.val) <= selected);
          });
        });

        star.addEventListener('click', () => {
          selected = parseInt(star.dataset.val);
          input.value = selected;
          stars.forEach(s => {
            s.classList.toggle('active', parseInt(s.dataset.val) <= selected);
          });
          if(labelEl) labelEl.textContent = starLabels[selected];
        });
      });
    });

    // Form submit
    const form = document.getElementById('feedbackForm');
    if(form) {
      form.addEventListener('submit', function(e) {
        const stallRating = document.getElementById('stallRating').value;
        if(!stallRating) {
          e.preventDefault();
          alert('Please rate the overall stall experience!');
          return;
        }

        e.preventDefault();

        // Submit via fetch and show modal
        const formData = new FormData(form);
        fetch(form.action, {
          method:'POST',
          body: new URLSearchParams(formData)
        }).then(res => {
          // Play success sound
          const sound = document.getElementById('successSound');
          sound.volume = 0.5;
          sound.play().catch(()=>{});

          // Confetti
          confetti({ particleCount:150, spread:70, origin:{y:0.6}, colors:['#ffd700','#ffaa00','#fff8dc','#ffa500'] });
          setTimeout(()=>{
            confetti({ particleCount:100, spread:120, origin:{y:0.6}, colors:['#ffd700','#ff6b6b','#ffffff'] });
          }, 500);

          // Show modal
          document.getElementById('successModal').classList.add('show');
        }).catch(err => {
          form.submit(); // fallback
        });
      });
    }
  </script>
</body>
</html>
